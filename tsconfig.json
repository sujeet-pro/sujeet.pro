{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "react",
    "jsxFactory": "h",
    "jsxFragmentFactory": "Fragment",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "scripts/**/*.ts",
    "layouts/**/*.tsx",
    "src/**/*.ts",
    "schemas/**/*.ts",
    "runtime/**/*.ts",
    "pagesmith.config.ts"
  ],
  "exclude": ["dist", "node_modules"]
}
