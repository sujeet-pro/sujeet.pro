%% Diagram: Upload flow with content-hash dedupe and async preset generation
%% Type: sequence
%%{init: {'htmlLabels': false}}%%
sequenceDiagram
    participant C as Client
    participant GW as Gateway
    participant U as Upload
    participant R as Registry
    participant S as Storage
    participant Q as Queue
    participant W as Worker

    C->>GW: POST /v1/assets
    GW->>GW: authn
    GW->>U: forward
    U->>U: validate
    U->>U: SHA-256
    U->>R: dedupe check
    alt Duplicate
        R-->>U: asset id
        U-->>C: 200 deduped
    else New
        U->>S: store
        S-->>U: key
        U->>R: create
        R-->>U: id
        U->>R: presets
        R-->>U: list
        loop preset
            U->>Q: enqueue
        end
        U-->>C: 201 + URLs
        Q->>W: dequeue
        W->>W: transform
        W->>S: store derived
        W->>R: save meta
        W->>R: cache
    end
