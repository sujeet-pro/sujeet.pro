    Transform["Transform Engine\nsync"]
    Upload["Asset Ingestion"]
    Control["Control Plane"]
    Registry[("Registry\nPostgreSQL")]
    Cache[("Redis Cache")]
    Queue["Queue\nRabbitMQ/SQS"]
    Workers["Transform Workers\nasync pool"]
    Adapter["Object Store\nAdapter"]
    Backends["Object Storage\nS3/GCS/Azure"]

    Client -->|HTTPS| CDN -->|miss| LB --> Gateway
    Gateway --> Transform
    Gateway --> Upload
    Gateway --> Control
    Transform --> Cache
    Transform --> Registry
    Transform --> Adapter
    Upload --> Registry
    Upload --> Queue
    Upload --> Adapter
    Control --> Registry
    Queue --> Workers
    Workers --> Adapter
    Workers --> Registry
    Adapter --> Backends
