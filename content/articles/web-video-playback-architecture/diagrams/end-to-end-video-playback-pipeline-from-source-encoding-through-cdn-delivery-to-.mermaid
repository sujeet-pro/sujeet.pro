%% Diagram: End To End Video Playback Pipeline From Source Encoding Through Cdn Delivery To
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph "Content Preparation"
        direction TB
        SRC[Source Video] --> ENC["Encoding\nH.264/H.265/AV1"]
        ENC --> PKG["Packaging\nfMP4/CMAF"]
        PKG --> DRM["DRM Encryption\nCENC"]
    end

    subgraph "Delivery"
        direction TB
        CDN["CDN Edge\nGlobal PoPs"]
        MAN["Manifest\nHLS/DASH"]
        CDN --> MAN
    end

    subgraph "Playback"
        direction TB
        ABR[ABR Selection]
        DEC["Decryption\n+ Decoding"]
        PLAY[Playback]
        ABR --> DEC --> PLAY
    end

    DRM --> CDN
    MAN --> ABR

    classDef prep fill:#5A5A5A,stroke:#3D3D3D,color:#ffffff
    classDef secure fill:#B43A3A,stroke:#8E2828,color:#ffffff
    classDef deliver fill:#8B5E15,stroke:#6E4810,color:#ffffff
    classDef play fill:#2D7A2D,stroke:#1E5A1E,color:#ffffff
    class SRC,ENC,PKG prep
    class DRM,DEC secure
    class CDN,MAN deliver
    class ABR,PLAY play
