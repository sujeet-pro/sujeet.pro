%% Diagram: PostgreSQL MVCC tuple visibility across concurrent transactions
%% Type: sequence
%%{init: {'htmlLabels': false}}%%
sequenceDiagram
    participant H as Heap
    participant T1 as T1 writer
    participant T2 as T2 (RC)
    participant T3 as T3 (RR)

    note over H: v1: xmin=100 xmax=0\nbalance=100

    T1->>H: BEGIN xid=200
    T2->>H: BEGIN, snapshot
    T3->>H: BEGIN, snapshot

    T2->>H: SELECT
    H-->>T2: v1 = 100

    T1->>H: UPDATE balance=150
    note over H: v1: xmin=100 xmax=200\nv2: xmin=200 xmax=0\n(xid 200 still in-progress)

    T3->>H: SELECT
    H-->>T3: v1 = 100\n(xmin=200 not in snapshot)

    T1->>H: COMMIT

    T2->>H: SELECT (re-read)
    H-->>T2: v2 = 150\n(fresh snapshot at RC)

    T3->>H: SELECT (re-read)
    H-->>T3: v1 = 100\n(snapshot frozen at BEGIN)
