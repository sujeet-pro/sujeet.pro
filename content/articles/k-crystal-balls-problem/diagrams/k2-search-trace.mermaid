%% Diagram: Optimal k=2 trace for N=100, threshold=37 using the T=14 decreasing-step plan
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    subgraph Phase1["Phase 1: egg #1 drops at 14, 27, 39 (steps 14, 13, 12)"]
        direction LR
        P14["floor 14<br/>safe"] --> P27["floor 27<br/>safe"] --> P39["floor 39<br/>BREAK"]
    end

    subgraph Phase2["Phase 2: egg #2 walks 28..38 linearly"]
        direction LR
        L28["floor 28<br/>safe"] --> L29["floor 29<br/>safe"] --> Ldots["..."] --> L36["floor 36<br/>safe"] --> L37["floor 37<br/>BREAK"]
    end

    Phase1 --> Phase2 --> Result["Threshold = 37<br/>Drops used = 3 + 10 = 13<br/>Worst-case bound = 14 (since 14*15/2 = 105 >= 100)"]
