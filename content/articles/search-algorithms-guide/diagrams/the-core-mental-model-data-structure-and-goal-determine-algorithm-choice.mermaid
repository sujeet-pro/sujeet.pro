%% Diagram: Core mental model — data structure plus goal determine algorithm choice
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Q["What are you searching?"]
    Q --> A["Array"]
    Q --> G["Graph"]

    A --> AS{"Sorted?"}
    AS -->|No| LS["Linear O(n)"]
    AS -->|Yes| BS["Binary O(log n)"]

    G --> GW{"Edge weights?"}
    GW -->|None — shortest path| BFS["BFS"]
    GW -->|None — any path| DFS["DFS"]
    GW -->|Non-negative| D["Dijkstra"]
    GW -->|Non-negative + heuristic| ASTAR["A*"]
    GW -->|Negative edges| BF["Bellman-Ford"]

    classDef question fill:#f1f5f9,stroke:#94a3b8,color:#0f172a
    classDef leaf fill:#2563eb,stroke:#1e40af,color:#ffffff
    class Q,AS,GW question
    class LS,BS,BFS,DFS,D,ASTAR,BF leaf
