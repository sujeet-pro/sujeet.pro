%% Diagram: High Level Architecture
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Clients["Clients\nMobile + Web"]
    EDGE["Edge\nCDN + Load Balancer"]
    WS["WebSocket Gateways\n(stateful, scaled)"]
    MSG["Message + Sync Service"]
    PRES["Presence Service"]
    KAFKA["Kafka Cluster"]
    FANOUT["Fan-out + Push Service\n(APNs + FCM)"]
    STATE["State Stores\nRedis · ScyllaDB · PostgreSQL"]

    Clients --> EDGE --> WS
    WS <--> MSG
    WS <--> PRES
    MSG --> KAFKA --> FANOUT
    FANOUT --> WS
    MSG --> STATE
    PRES --> STATE
