%% Diagram: Diagram 4
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    CLIENT["Client\nWS Client + Local Cache"]
    EDGE["Edge\nGeoDNS · NLB"]
    WS_GW["WebSocket Gateway\nstateful conns"]
    MSG_SVC["Message Service"]
    PRES_SVC["Presence Service"]
    OTHER_SVC["Other Services\nUser · Group · Sync · Push"]
    KAFKA["Kafka\nfanout topics"]
    STATE["State Stores\nRedis · ScyllaDB · PG · S3"]

    CLIENT --> EDGE --> WS_GW
    WS_GW <--> MSG_SVC
    WS_GW <--> PRES_SVC
    MSG_SVC --> KAFKA
    MSG_SVC --> OTHER_SVC
    KAFKA --> WS_GW
    KAFKA --> OTHER_SVC
    MSG_SVC --> STATE
    PRES_SVC --> STATE
    OTHER_SVC --> STATE
    WS_GW --> STATE
