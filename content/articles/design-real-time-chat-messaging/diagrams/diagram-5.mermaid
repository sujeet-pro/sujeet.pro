flowchart TB
    R53["Route 53 GeoDNS"]
    CF["CloudFront"]
    WS["WebSocket Pods (Fargate)"]
    MSG["Message Service"]
    SYNC["Sync Service"]
    FANOUT["Fan-out + Push Workers"]
    MSK["MSK Kafka"]
    DATA["Storage\nRedis · Keyspaces · RDS · S3"]
    SNS["SNS Mobile Push"]

    R53 --> CF --> WS
    WS --> MSG --> MSK
    WS --> DATA
    MSG --> DATA
    SYNC --> DATA
    MSK --> FANOUT --> WS
    FANOUT --> SNS
