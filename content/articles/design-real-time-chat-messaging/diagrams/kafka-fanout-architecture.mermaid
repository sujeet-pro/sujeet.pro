%% Diagram: Kafka Fan-out Architecture
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Publish
        SENDER["Sender"]
        GW1["Gateway"]
        MSG["Message Service"]
    end

    subgraph Queue
        KAFKA["Kafka topic\npartitioned by conversation_id"]
    end

    subgraph Subscribe
        FO1["Fan-out Worker 1"]
        FO2["Fan-out Worker 2"]
        FOn["Fan-out Worker N"]
    end

    subgraph Deliver
        GW2["Gateway pool"]
        PUSH["Push Gateway\nAPNs + FCM"]
        RECIP["Recipients"]
    end

    SENDER --> GW1 --> MSG --> KAFKA
    KAFKA --> FO1 & FO2 & FOn
    FO1 & FO2 & FOn --> GW2 --> RECIP
    FO1 & FO2 & FOn --> PUSH
