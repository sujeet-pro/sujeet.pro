flowchart TD
    subgraph "Client Request"
        C[Web/Mobile Client]
    end

    subgraph "Region A"
        subgraph "Follower Tier"
            F1[Follower Cache 1]
            F2[Follower Cache N]
        end
        subgraph "Leader Tier"
            L[Leader Cache]
        end
        subgraph "Storage"
            DB[(MySQL Primary)]
        end
    end

    subgraph "Region B (Replica)"
        subgraph "Follower Tier B"
            F3[Follower Cache]
        end
        subgraph "Leader Tier B"
            L2[Leader Cache]
        end
        subgraph "Storage B"
            DB2[(MySQL Replica)]
        end
    end

    C -->|Read| F1
    C -->|Write| F1
    F1 -->|Miss/Write| L
    L -->|Write-through| DB
    DB -->|Replicate| DB2
    L -->|Async Invalidation| F1
    L -->|Async Invalidation| F2
