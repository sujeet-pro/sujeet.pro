%% Diagram: Api Architecture Clients Connect Through A Gateway That Handles Rate Limiting An
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Clients["Clients"]
        Web[Web Browser]
        Mobile[Mobile App]
        Service[Internal Service]
    end

    subgraph Gateway["API Gateway"]
        GW[Gateway Layer]
        RL[Rate Limiter]
        Auth[Auth/Validation]
    end

    subgraph Protocols["Protocol Layer"]
        REST[REST/HTTP]
        GRPC[gRPC]
        GQL[GraphQL]
    end

    subgraph Backend["Backend Services"]
        S1[Service A]
        S2[Service B]
        S3[Service C]
    end

    Web --> GW
    Mobile --> GW
    Service --> GW
    GW --> RL --> Auth
    Auth --> REST & GRPC & GQL
    REST --> S1
    GRPC --> S2
    GQL --> S1 & S2 & S3
