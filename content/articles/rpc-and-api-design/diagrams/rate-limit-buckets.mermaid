%% Diagram: Token bucket vs leaky bucket — burst behavior at the edge
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Req([Request]) --> Mode{Algorithm}

    Mode -- token bucket --> TBCheck{"Token\navailable?"}
    Refill["Refiller\n+r tokens/sec"] --> Bucket[("Bucket\ncapacity = burst")]
    Bucket --> TBCheck
    TBCheck -- yes --> TBPass["Pass\nburst-friendly"]:::pass
    TBCheck -- no --> TBDrop["429\nToo Many Requests"]:::drop

    Mode -- leaky bucket --> LBQ{"Queue\nfull?"}
    LBQ -- no --> Queue[(Queue capacity)]
    LBQ -- yes --> LBDrop["429\nToo Many Requests"]:::drop
    Queue --> Leak[Drain at fixed rate r]
    Leak --> LBPass["Pass\nsmoothed output"]:::pass

    classDef pass fill:#2D7A2D,stroke:#1E5A1E,color:#ffffff
    classDef drop fill:#B43A3A,stroke:#8E2828,color:#ffffff
