%% Diagram: Trees Model Hierarchical Relationships Graphs Model Arbitrary Connections Traver
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Trees["Trees (Hierarchical)"]
        BST["BST\nO(log n)"]
        AVL["AVL"]
        RB["Red-Black"]
        BTree["B-Tree"]
        Trie["Trie"]
    end

    subgraph Graphs["Graphs"]
        AdjMatrix["Adjacency Matrix"]
        AdjList["Adjacency List"]
    end

    subgraph Traversals["Traversals"]
        DFS["DFS"]
        BFS["BFS"]
    end

    Trees --> Traversals
    Graphs --> Traversals
