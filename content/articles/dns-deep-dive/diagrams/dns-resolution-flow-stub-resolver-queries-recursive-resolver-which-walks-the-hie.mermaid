%% Diagram: DNS Resolution Flow
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    App["Application"]
    Stub["Stub Resolver"]
    Resolver["Recursive Resolver\n(ISP/Public, with Cache)"]
    Hierarchy["DNS Hierarchy walk\nRoot → TLD → Authoritative"]

    App -->|"1. gethostbyname"| Stub
    Stub -->|"2. Query"| Resolver
    Resolver -->|"3-9. Recursive walk\n(cached or live)"| Hierarchy
    Hierarchy -->|"Final answer"| Resolver
    Resolver -->|"10. Return + cache"| Stub
    Stub -->|"11. Return IP"| App
