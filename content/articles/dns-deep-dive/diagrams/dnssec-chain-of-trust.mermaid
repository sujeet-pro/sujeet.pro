%% Diagram: DNSSEC chain of trust (root → TLD → leaf zone)
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Anchor["Trust anchor\n(root KSK preconfigured\nin validator)"]

    subgraph RootZone["Root zone (.)"]
      direction LR
      RootKey["DNSKEY\n(KSK + ZSK)"]
      RootDS["DS for .com\n(in root, signed)"]
      RootKey -->|signs| RootDS
    end

    subgraph TLDZone[".com zone"]
      direction LR
      TLDKey["DNSKEY\n(KSK + ZSK)"]
      TLDDS["DS for example.com\n(in .com, signed)"]
      TLDKey -->|signs| TLDDS
    end

    subgraph Leaf["example.com zone"]
      direction LR
      LeafKey["DNSKEY\n(KSK + ZSK)"]
      RRSIG["RRSIG over A / MX / TXT\n(signed by ZSK)"]
      LeafKey -->|signs| RRSIG
    end

    Anchor --> RootKey
    RootDS -->|hash matches| TLDKey
    TLDDS -->|hash matches| LeafKey
