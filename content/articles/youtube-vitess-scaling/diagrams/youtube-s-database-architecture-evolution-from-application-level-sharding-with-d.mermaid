%% Diagram: Youtube S Database Architecture Evolution From Application Level Sharding With D
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph BV["Before Vitess (2006)"]
        direction TB
        A1[Application Code]
        A1 -->|"Shard-aware queries<br/>routing logic embedded"| M1[MySQL Shards 1..4]
    end

    subgraph WV["With Vitess (2011+)"]
        direction TB
        A2[Application Code]
        A2 -->|"MySQL protocol<br/>shard-unaware"| VG[VTGate<br/>Stateless Proxy]
        VG --> VT[VTTablet + MySQL<br/>Shards 1..256]
        TS[Topology Service] -.->|"Shard map<br/>health checks"| VG
    end

    BV ~~~ WV
