%% Diagram: Leader Based Consensus Client Writes Go Through The Leader Which Replicates To F
%% Type: flowchart
flowchart TB
    subgraph Consensus["Consensus Protocol"]
        direction TB
        L[Leader]
        F1[Follower 1]
        F2[Follower 2]
        F3[Follower 3]
    end

    C[Client] -->|"1. Write request"| L
    L -->|"2. Replicate log entry"| F1
    L -->|"2. Replicate log entry"| F2
    L -->|"2. Replicate log entry"| F3
    F1 -->|"3. Acknowledge"| L
    F2 -->|"3. Acknowledge"| L
    L -->|"4. Commit (majority acked)"| L
    L -->|"5. Respond"| C
