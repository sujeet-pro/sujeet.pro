%% Diagram: February 22, 2022 cascading failure
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Trigger["Trigger: Consul agent rolling upgrade (~25%)"]
    Cache["memcached deregistered → replaced cold"]
    Scatter["Group-DM membership scatter query<br/>fans out across all user-id shards"]
    DBLoad["Vitess replicas overloaded; cache cannot refill"]
    Throttle["Mitigation: throttle client boots"]
    Rewrite["Rewrite query to channel-sharded co-located table"]
    Recovery["Cache warms → boots resume"]

    Trigger --> Cache --> Scatter --> DBLoad
    DBLoad -->|self-reinforcing loop| DBLoad
    DBLoad --> Throttle --> Rewrite --> Recovery

    style Trigger fill:#fca5a5,stroke:#991b1b,color:#7f1d1d
    style DBLoad fill:#fbbf24,stroke:#b45309,color:#451a03
    style Throttle fill:#818cf8,stroke:#4338ca,color:#ffffff
    style Recovery fill:#34d399,stroke:#1E5A1E,color:#ffffff
