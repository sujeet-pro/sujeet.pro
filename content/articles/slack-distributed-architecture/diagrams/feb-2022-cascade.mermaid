%% Diagram: February 22, 2022 cascading failure
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Trigger["Trigger\nConsul agent rolling upgrade (~25%)"]
    Cache["Cold caches\nmemcached deregistered, replaced empty"]
    Scatter["Scatter query amplification\ngroup-DM membership fans out\nacross every user-id shard"]
    DBLoad["Vitess overload\nreplicas saturated; cache cannot refill"]
    Throttle["Mitigation\nthrottle client boots"]
    Rewrite["Schema fix\nrewrite query to channel-sharded\nco-located table"]
    Recovery["Recovery\ncache warms, boots resume"]

    Trigger --> Cache --> Scatter --> DBLoad
    DBLoad -- "self-reinforcing loop" --> DBLoad
    DBLoad --> Throttle --> Rewrite --> Recovery

    style Trigger fill:#B43A3A,stroke:#8E2828,color:#ffffff
    style DBLoad fill:#8B5E15,stroke:#6E4810,color:#ffffff
    style Throttle fill:#2E5A88,stroke:#1F4870,color:#ffffff
    style Recovery fill:#2D7A2D,stroke:#1E5A1E,color:#ffffff
