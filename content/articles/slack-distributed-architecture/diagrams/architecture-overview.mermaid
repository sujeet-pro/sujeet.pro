%% Diagram: Slack distributed architecture overview (~2023)
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Edge["Edge (multi-region)"]
        Envoy["Envoy\nload balancing, AZ routing"]
        Flannel["Flannel\nedge cache, consistent hashing"]
    end

    subgraph RTM["Real-time messaging"]
        GS["Gateway Servers\nWebSocket termination"]
        CS["Channel Servers\npub/sub, ~16M channels/host"]
        AS["Admin Servers\nstateless routing"]
        CHARM["CHARM\nhash-ring manager"]
    end

    subgraph Compute["Application"]
        Webapp["Webapp Monolith\nPHP/Hack on HHVM"]
        JobQ["Job Queue\n9B jobs/day"]
        Search["Search\nSolr + ML re-rank"]
    end

    subgraph Data["Data layer"]
        Vitess["Vitess\n2.3M QPS, multi-keyspace"]
        MC["Memcached + Mcrouter"]
        Kafka["Kafka\nevent stream"]
        S3["S3\nwarehouse / Parquet"]
    end

    subgraph Infra["Control"]
        Consul["Consul\nservice discovery"]
        Rotor["Rotor\nxDS control plane"]
    end

    Envoy --> Flannel
    Flannel --> GS
    GS --> CS
    Webapp --> AS --> CS
    Webapp --> Vitess
    Webapp --> MC
    Webapp --> Search
    Webapp --> JobQ
    JobQ --> Vitess
    CS --> GS
    Vitess --> Kafka --> S3
    Consul --> Rotor --> Envoy
    CHARM -.manages.-> CS

    style Envoy fill:#2E5A88,stroke:#1F4870,color:#ffffff
    style Flannel fill:#2E5A88,stroke:#1F4870,color:#ffffff
    style Vitess fill:#8B5E15,stroke:#6E4810,color:#ffffff
    style Webapp fill:#2D7A2D,stroke:#1E5A1E,color:#ffffff
