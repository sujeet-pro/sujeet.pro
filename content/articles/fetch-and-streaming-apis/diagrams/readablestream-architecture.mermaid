%% Diagram: ReadableStream internal architecture and consumer surface
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Source["Underlying source"]
        PUSH["Push source\n(events, sockets)"]
        PULL["Pull source\n(file, db, fetch body)"]
    end

    subgraph Stream["ReadableStream"]
        QUEUE["Internal chunk queue"]
        CTRL["controller\nenqueue / close / error"]
        DS["controller.desiredSize\n= highWaterMark - queueSize"]
    end

    subgraph Consumer["Consumer (one at a time)"]
        READER["getReader"]
        ITER["for await of"]
        PIPE["pipeTo / pipeThrough"]
    end

    PUSH -->|enqueue| QUEUE
    PULL -->|pull| QUEUE
    QUEUE --> READER
    QUEUE --> ITER
    QUEUE --> PIPE

    DS -.->|stop producing when zero or less| PUSH
    DS -.->|delay next pull| PULL

    classDef primary fill:#2E5A88,stroke:#1F4870,color:#ffffff
    classDef accent fill:#B43A3A,stroke:#8E2828,color:#ffffff
    class QUEUE primary
    class DS accent
