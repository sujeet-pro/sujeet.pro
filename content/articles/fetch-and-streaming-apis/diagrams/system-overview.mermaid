%% Diagram: System overview - how Fetch, Streams, and AbortController compose
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Fetch["Fetch API"]
        REQ["Request"] --> NET["network\n(HTTP/1.1, /2, /3)"]
        NET --> RESP["Response"]
        RESP --> BODY["response.body\n(ReadableStream)"]
    end

    subgraph Streams["Streams API"]
        RS["ReadableStream"] -->|pipeThrough| TS["TransformStream"]
        TS -->|pipeTo| WS["WritableStream"]
        WS -.->|desiredSize| TS
        TS -.->|desiredSize| RS
    end

    subgraph Abort["AbortController"]
        AC["AbortController"] --> SIG["AbortSignal"]
        SIG -->|cancels network| NET
        SIG -->|cancels pipe| TS
        SIG -->|cancels reader| RS
    end

    BODY --> RS

    classDef fetchBox fill:#2E5A88,stroke:#1F4870,color:#ffffff
    classDef streamsBox fill:#1F6E68,stroke:#155752,color:#ffffff
    classDef abortBox fill:#8B5E15,stroke:#6E4810,color:#ffffff
    class REQ,NET,RESP,BODY fetchBox
    class RS,TS,WS streamsBox
    class AC,SIG abortBox
