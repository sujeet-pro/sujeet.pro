%% Diagram: Go sawtooth vs Rust flat latency — stylized read of Discord's published charts
%% Type: xy
%%{init: {'htmlLabels': false}}%%
xychart-beta
    title "Read States response time: Go (sawtooth) vs Rust (flat)"
    x-axis "Time (minutes)" [0, 2, 4, 6, 8, 10, 12]
    y-axis "Response time (ms)" 0 --> 50
    line "Go p99 (forced GC every 2 min)" [1, 35, 1, 40, 1, 30, 1]
    line "Rust p99 (no GC)" [0.5, 0.6, 0.5, 0.5, 0.6, 0.5, 0.5]
