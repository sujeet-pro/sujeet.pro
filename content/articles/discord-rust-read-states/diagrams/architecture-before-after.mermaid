%% Diagram: Discord Read States — before and after the Rust rewrite
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Go["Go Implementation (~2017-2019)"]
        direction TB
        GoLRU["LRU Cache\n(HashMap, tens of millions of entries)"]:::neutral
        GoGC["Go GC\ntri-color mark-and-sweep"]:::alert
        GoCass[("Cassandra")]:::storage
        GoLRU --> GoCass
        GoGC -.->|"scans entire cache\nevery ~2 min"| GoLRU
    end

    subgraph Rust["Rust Implementation (2019+)"]
        direction TB
        RustLRU["LRU Cache\n(BTreeMap, 8M entries)"]:::neutral
        RustDrop["Ownership + Drop\ndeterministic deallocation"]:::success
        RustCass[("Cassandra")]:::storage
        RustLRU --> RustCass
        RustDrop -.->|"freed immediately\non eviction"| RustLRU
    end

    Go ==>|"Rewrite ~May 2019"| Rust

    classDef alert fill:#B43A3A,stroke:#8E2828,color:#ffffff
    classDef success fill:#2D7A2D,stroke:#1E5A1E,color:#ffffff
    classDef storage fill:#8B5E15,stroke:#6E4810,color:#ffffff
    classDef neutral fill:#5A5A5A,stroke:#3D3D3D,color:#ffffff
