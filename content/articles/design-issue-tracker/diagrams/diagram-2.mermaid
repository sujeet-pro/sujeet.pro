%% Diagram: Diagram 2
%% Type: flowchart
flowchart LR
    subgraph Client["Client"]
        UI["UI Layer"]
        STORE["Local Store<br/>(IndexedDB)"]
        SYNC["Sync Client"]
    end

    subgraph Server["Server"]
        SYNC_SVC["Sync Service"]
        DB[(PostgreSQL)]
    end

    UI <--> STORE
    STORE <--> SYNC
    SYNC <-->|"Delta Packets"| SYNC_SVC
    SYNC_SVC <--> DB
