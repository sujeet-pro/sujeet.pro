%% Diagram: Project-scoped workflow entity model
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    PROJECT["PROJECT\n---\nuuid id (PK)\nstring key\nstring name"]
    STATUS["STATUS\n---\nuuid id (PK)\nuuid project_id (FK)\nstring name\nstring category\nint position"]
    WT["WORKFLOW_TRANSITION\n---\nuuid id (PK)\nuuid project_id (FK)\nuuid from_status_id (FK)\nuuid to_status_id (FK)\nstring name\nint opsbar_sequence"]

    PROJECT -->|has many| STATUS
    PROJECT -->|has many| WT
    STATUS -->|from| WT
    STATUS -->|to| WT

    classDef entity fill:#2E5A88,stroke:#1F4870,color:#ffffff
    class PROJECT,STATUS,WT entity
