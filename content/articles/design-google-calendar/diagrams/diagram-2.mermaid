%% Diagram: Diagram 2
%% Type: sequence
%%{init: {'htmlLabels': false}}%%
sequenceDiagram
    participant C as Client
    participant API
    participant ES as Event
    participant RS as Recurrence
    participant DB
    participant Cache

    C->>API: GET events?range
    API->>ES: getEvents
    ES->>Cache: lookup
    alt Hit
        Cache->>ES: cached
    else Miss
        ES->>DB: single events
        ES->>DB: instances
        alt Beyond window
            ES->>RS: expand
            RS->>ES: instances
        end
        ES->>ES: merge
        ES->>Cache: SET 5m
    end
    ES->>C: events
