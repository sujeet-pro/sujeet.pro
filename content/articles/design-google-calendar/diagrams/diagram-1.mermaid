%% Diagram: Diagram 1
%% Type: sequence
%%{init: {'htmlLabels': false}}%%
sequenceDiagram
    participant C as Client
    participant API as API
    participant ES as Event
    participant RS as Recurrence
    participant DB as DB
    participant Cache as Cache
    participant Q as Queue

    C->>API: POST /events (RRULE)
    API->>ES: createEvent
    ES->>DB: INSERT master
    ES->>RS: expand 90d
    RS->>DB: INSERT instances
    RS->>Cache: invalidate free/busy
    ES->>Q: EventCreated
    ES->>C: 201 Created
