%% Diagram: RRULE expansion pipeline — master + EXDATE + RDATE + exception override → rendered series
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    Master["events row<br/>DTSTART 2026-01-19 09:00 (TZID America/New_York)<br/>RRULE FREQ=WEEKLY;BYDAY=MO,WE,FR"]
    Exdate["EXDATE<br/>2026-01-21"]
    Rdate["RDATE<br/>2026-01-20"]
    Exception["exception row<br/>originalStart 2026-01-23<br/>start moved to 10:00"]

    Raw["raw RRULE expansion<br/>Mon 1/19, Wed 1/21, Fri 1/23"]
    Minus["after EXDATE<br/>Mon 1/19, Fri 1/23"]
    Plus["after RDATE<br/>Mon 1/19, Tue 1/20, Fri 1/23"]
    Final["rendered series<br/>Mon 1/19 09:00<br/>Tue 1/20 09:00<br/>Fri 1/23 10:00 (overridden)"]

    Master --> Raw
    Raw --> Minus
    Exdate --> Minus
    Minus --> Plus
    Rdate --> Plus
    Plus --> Final
    Exception --> Final
