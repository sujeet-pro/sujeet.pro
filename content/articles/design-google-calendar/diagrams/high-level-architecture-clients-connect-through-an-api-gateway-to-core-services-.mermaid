%% Diagram: High Level Architecture Clients Connect Through An Api Gateway To Core Services
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    CLIENTS["Clients\nWeb / Mobile / Desktop / Email"]
    LB["LB"]
    Auth["Auth"]
    RL["Rate Limiter"]
    EventSvc["Event"]
    RecurrenceSvc["Recurrence"]
    SchedulingSvc["Scheduling"]
    NotifSvc["Notif"]
    SyncSvc["Sync"]
    PG[(Postgres)]
    Redis[(Redis)]
    ES[(ES)]
    S3[(S3)]
    Queue["Queue"]
    Workers["Workers"]
    Scheduler["Scheduler"]

    CLIENTS --> LB --> Auth --> RL
    RL --> EventSvc & RecurrenceSvc & SchedulingSvc & NotifSvc & SyncSvc
    EventSvc --> PG
    SchedulingSvc --> Redis
    EventSvc --> ES
    EventSvc --> S3
    NotifSvc --> Queue --> Workers
    Scheduler --> Workers
