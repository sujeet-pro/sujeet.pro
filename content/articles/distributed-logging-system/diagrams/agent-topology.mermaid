%% Diagram: Agent Topology — DaemonSet vs Sidecar
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph DS["DaemonSet — one shared agent per node"]
        direction TB
        subgraph N["Node"]
            direction TB
            P1[Pod A] --> A1["Agent\nshared by all pods"]
            P2[Pod B] --> A1
            P3[Pod C] --> A1
        end
    end

    subgraph SC["Sidecar — one dedicated agent per pod"]
        direction TB
        subgraph PA["Pod A"]
            APP1[App] --> SA1[Agent]
        end
        subgraph PB["Pod B"]
            APP2[App] --> SA2[Agent]
        end
    end

    A1 --> Q[("Buffer")]
    SA1 --> Q
    SA2 --> Q

    classDef pod fill:#2E5A88,stroke:#1F4870,color:#ffffff
    classDef agent fill:#1F6E68,stroke:#155752,color:#ffffff
    classDef queue fill:#8B5E15,stroke:#6E4810,color:#ffffff

    class P1,P2,P3,APP1,APP2 pod
    class A1,SA1,SA2 agent
    class Q queue
