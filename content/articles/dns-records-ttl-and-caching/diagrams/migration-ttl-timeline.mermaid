%% Diagram: Migration TTL lowering timeline — phased TTL changes with safe-cutover window
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    subgraph Auth["Authoritative state"]
        direction TB
        A1["Day 0\nold value @ TTL 3600 s"]
        A2["Day 1\nlower TTL to 300 s"]
        A3["Day 2\nold value, TTL = 300 s"]
        A4["Day 3\nchange record, TTL 300 s"]
        A5["Day 4\nverify on resolvers"]
        A6["Day 5\nrestore TTL to 3600 s"]
        A1 --> A2 --> A3 --> A4 --> A5 --> A6
    end
    subgraph Cache["Resolver cache state"]
        direction TB
        R1["old value cached"]
        R2["still old value\nuntil 3600 s expires"]
        R3["mix: old + new\nTTL refreshes"]
        R4["new value within 300 s"]
        R5["stable on new value"]
        R6["stable, longer TTL\nresumes amortising"]
        R1 --> R2 --> R3 --> R4 --> R5 --> R6
    end

    A1 -.-> R1
    A2 -.-> R2
    A3 -.-> R3
    A4 -.-> R4
    A5 -.-> R5
    A6 -.-> R6

    classDef baseline fill:#5A5A5A,stroke:#3D3D3D,color:#ffffff
    classDef change fill:#B43A3A,stroke:#8E2828,color:#ffffff
    classDef drain fill:#8B5E15,stroke:#6E4810,color:#ffffff
    classDef stable fill:#2D7A2D,stroke:#1E5A1E,color:#ffffff

    class A1,R1 baseline
    class A2,R2 change
    class A3,R3 drain
    class A4,R4 change
    class A5,R5 stable
    class A6,R6 stable
