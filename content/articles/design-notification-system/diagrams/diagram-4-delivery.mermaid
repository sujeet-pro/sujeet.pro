%% Diagram: Diagram 4 — Routing + delivery + storage
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Queue["Message Queues (4 priorities)"]
        direction TB
        QUEUES["Critical / High / Normal / Bulk"]
    end

    subgraph Router["Routing Layer"]
        direction TB
        ROUTER["Router Service"]
        THROTTLE["User Throttler"]
        AGGREGATE["Aggregator"]
        DEDUP["Dedup Service"]
    end

    subgraph Channels["Channel Processors"]
        direction TB
        PUSH_PROC["Push Processor"]
        EMAIL_PROC["Email Processor"]
        SMS_PROC["SMS Processor"]
        INAPP_PROC["In-App Processor"]
    end

    subgraph External["External Providers"]
        direction TB
        APNS["APNs"]
        FCM["FCM"]
        SES["Amazon SES"]
        TWILIO["Twilio"]
    end

    subgraph Storage["Storage"]
        direction TB
        REDIS["Redis Cluster"]
        PG[(PostgreSQL)]
        CASS[(Cassandra)]
        S3["S3 (Attachments)"]
    end

    QUEUES --> ROUTER
    ROUTER --> THROTTLE & AGGREGATE & DEDUP
    ROUTER --> PUSH_PROC & EMAIL_PROC & SMS_PROC & INAPP_PROC
    PUSH_PROC --> APNS & FCM
    EMAIL_PROC --> SES
    SMS_PROC --> TWILIO
    INAPP_PROC --> REDIS
    THROTTLE --> REDIS
    ROUTER --> CASS
