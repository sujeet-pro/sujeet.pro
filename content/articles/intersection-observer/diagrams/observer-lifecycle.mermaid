graph TD
    create["new IntersectionObserver"] --> configure["Configure Options"]
    configure --> observe["observe(element)"]
    observe --> monitor["Browser Monitors Visibility"]
    monitor -->|"Crosses threshold"| callback["Callback Fires"]
    callback --> check{"isIntersecting?"}
    check -->|"Entering"| action["Trigger Action"]
    check -->|"Leaving"| leaving["Element Left Viewport"]
    action --> oneshot{"One-time?"}
    oneshot -->|"Yes"| unobserve["unobserve(element)"]
    oneshot -->|"No"| monitor
    leaving --> monitor
