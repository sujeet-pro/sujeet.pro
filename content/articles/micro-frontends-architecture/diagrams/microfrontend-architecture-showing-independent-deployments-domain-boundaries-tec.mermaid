%% Diagram: Microfrontend Architecture Showing Independent Deployments Domain Boundaries Tec
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
graph TB
    title[Microfrontend Architecture]

    E[Team A - React] --> F[Independent Deployments]
    G[Team B - Vue] --> F
    H[Team C - Angular] --> F
    I[Team D - Svelte] --> F

    F --> J[Domain Boundaries]
    J --> K[Technology Freedom]
    K --> L[Team Autonomy]

    classDef header fill:#2D7A2D,stroke:#1E5A1E,color:#ffffff
    classDef teamNode fill:#1F6E68,stroke:#155752,color:#ffffff
    classDef benefit fill:#5A5A5A,stroke:#3D3D3D,color:#ffffff
    class title header
    class E,G,H,I teamNode
    class F,J,K,L benefit
