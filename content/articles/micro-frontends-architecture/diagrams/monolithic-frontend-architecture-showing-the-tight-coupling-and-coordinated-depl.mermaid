%% Diagram: Monolithic Frontend Architecture Showing The Tight Coupling And Coordinated Depl
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
graph TB
    title[Monolithic Frontend Architecture]

    A[Single Codebase] --> B[Shared Dependencies]
    B --> C[Tight Coupling]
    C --> D[Coordinated Deployments]

    classDef header fill:#B43A3A,stroke:#8E2828,color:#ffffff
    classDef primary fill:#8B5E15,stroke:#6E4810,color:#ffffff
    classDef secondary fill:#5A5A5A,stroke:#3D3D3D,color:#ffffff
    class title header
    class A primary
    class B,C,D secondary
