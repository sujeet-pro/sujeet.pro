%% Diagram: High Level Architecture
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Clients["Clients\nWeb, API, CLI"]
    CDN["CDN Edge Cache\nCloudFront/Fastly"]
    LB["Load Balancer"]
    PASTE_SVC["Paste Service\nWrite Path"]
    READ_SVC["Read Service\nCache-aside Read"]
    HELPERS["Helpers\nKey Gen, Highlight, Rate Limit, Scanner"]
    STORAGE["Storage\nRedis · PostgreSQL · S3"]
    EXPIRY["Expiration Service"]

    Clients --> CDN
    CDN -->|Cache Miss| LB
    LB --> PASTE_SVC
    LB --> READ_SVC
    PASTE_SVC --> HELPERS
    PASTE_SVC --> STORAGE
    READ_SVC --> STORAGE
    EXPIRY --> STORAGE
