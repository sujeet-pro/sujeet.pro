%% Diagram: Pastebin (Read & Lifecycle)
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    CLIENTS["Clients\nBrowser, CLI, SDK"]
    CDN["CDN\nimmutable cache"]
    LB["Load Balancer"]
    ROUTER["API Router"]
    READ["Paste Read Service"]
    EXPIRY["Expiration Service"]
    ABUSE["Abuse Detection"]

    subgraph Storage["Storage"]
        REDIS["Redis Cluster"]
        PG[(PostgreSQL)]
        S3["S3"]
    end

    CLIENTS --> CDN -->|miss| LB --> ROUTER --> READ
    READ --> REDIS
    READ -->|miss| PG
    READ -->|miss| S3
    EXPIRY --> REDIS
    EXPIRY --> PG
    EXPIRY --> S3
    ABUSE --> REDIS
