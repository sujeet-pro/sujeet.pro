%% Diagram: Multiple Frame Sources Converge In Viz To Produce A Single Aggregated Output
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    subgraph Inputs["Frame Sources"]
        BUI[Browser UI]
        R1[Renderer: Main Page]
        R2[Renderer: iframe A]
        R3[Renderer: iframe B]
    end

    subgraph Viz["Viz Process"]
        SA[Surface Aggregator]
    end

    subgraph Output["Single Output"]
        GPU[GPU Commands]
        Display[Display]
    end

    BUI --> SA
    R1 --> SA
    R2 --> SA
    R3 --> SA
    SA --> GPU --> Display
