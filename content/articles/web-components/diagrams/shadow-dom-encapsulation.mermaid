%% Diagram: Shadow Dom Encapsulation
%% Type: flowchart
flowchart LR
  subgraph Page["Document (light DOM)"]
    Host["Host: my-card"]
    Light["Light DOM children"]
    ExtCSS["Page CSS / selectors"]
  end

  subgraph Shadow["Shadow tree (scoped)"]
    SR["Shadow root"]
    IntCSS["Internal styles"]
    Slots["slot insertion points"]
  end

  Host --> SR
  Light -.->|"projection (composed tree)"| Slots
  ExtCSS -.->|"default: no pierce"| SR
  IntCSS --> Slots
