flowchart LR
    subgraph Deploy["Deployment (Infrastructure)"]
        D1[v1.0] --> D2[v1.1 with flag]
    end

    subgraph Release["Release (Feature Flags)"]
        F1[Flag: OFF] --> F2[Flag: 1%]
        F2 --> F3[Flag: 10%]
        F3 --> F4[Flag: 100%]
    end

    D2 -.-> F1
    F4 -.-> USERS[All Users]
