%% Diagram: Diagram 6
%% Type: flowchart
flowchart LR
    MSG["Incoming<br/>Message"] --> BL["Blocklist<br/>Check"]
    BL -->|Listed| SPAM["Spam"]
    BL -->|Clean| AUTH["Auth<br/>Check"]
    AUTH -->|Fail| SPAM
    AUTH -->|Pass/Partial| HEUR["Heuristic<br/>Rules"]
    HEUR --> ML["ML<br/>Classifier"]
    ML -->|Score| DECISION{"Score<br/>> 0.9?"}
    DECISION -->|Yes| SPAM
    DECISION -->|No| INBOX["Inbox"]
