%% Diagram: High Level Architecture Separate Inbound Receiving And Outbound Sending Mail Pat
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    CLIENTS["Clients\nWeb / Mobile / Desktop"]
    EDGE["Edge"]
    MX["MX"]
    AUTH["SPF/DKIM"]
    SPAM["Spam"]
    ROUTE["Router"]
    SUBMIT["Submit"]
    QUEUE["Queue"]
    MTA["MTA"]
    API["API"]
    MAILBOX["Mailbox"]
    SEARCH["Search"]
    THREAD["Thread"]
    LABEL["Label"]
    META[(PG)]
    MSG[(Cassandra)]
    IDX[(ES)]
    BLOB["S3"]
    CACHE["Redis"]

    CLIENTS --> EDGE --> API
    CLIENTS -->|IMAP| MAILBOX
    CLIENTS -->|SMTP| SUBMIT
    MX --> AUTH --> SPAM --> ROUTE --> MAILBOX
    SUBMIT --> QUEUE --> MTA
    API --> MAILBOX
    API --> SEARCH
    API --> THREAD
    API --> LABEL
    MAILBOX --> META
    MAILBOX --> MSG
    MAILBOX --> BLOB
    SEARCH --> IDX
    MAILBOX --> CACHE
