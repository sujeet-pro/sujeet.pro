%% Diagram: S2 vs H3 spatial cell hierarchy
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    subgraph S2["Google S2 — quadrilateral cells, strict 4-way hierarchy (levels 0–30)"]
        direction TB
        S2Sphere["Sphere"] --> S2Cube["Project to cube (6 faces)"]
        S2Cube --> S2L0["Level 0: 6 face cells"]
        S2L0 --> S2L1["Level 1: 24 cells"]
        S2L1 --> S2L30["...Level 30 (~0.7 cm²)"]
        S2L30 --> S2ID["64-bit cell ID on a<br/>single Hilbert curve<br/>(locality preserved)"]
    end

    subgraph H3["Uber H3 — hexagons on icosahedron, approximate hierarchy (resolutions 0–15)"]
        direction TB
        H3Sphere["Sphere"] --> H3Ico["Project to icosahedron (20 faces)"]
        H3Ico --> H3R0["Resolution 0: 122 cells<br/>(110 hex + 12 pentagons)"]
        H3R0 --> H3R1["Resolution 1: ~7× more"]
        H3R1 --> H3R15["...Resolution 15 (~0.9 m²)"]
        H3R15 --> H3Note["Children may extend<br/>outside the parent —<br/>containment is approximate"]
    end
