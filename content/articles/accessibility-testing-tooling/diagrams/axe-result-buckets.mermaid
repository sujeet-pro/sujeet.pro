%% Diagram: axe-core result categories and what to do with each
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Run["axe.run() result"]:::neutral
    Run --> V["violations\ndefinite failures"]:::fail
    Run --> P["passes\ndefinite passes"]:::pass
    Run --> I["incomplete\nheuristics fired,\nneeds human review"]:::warn
    Run --> N["inapplicable\nrule did not match\nanything on page"]:::neutral

    V --> VA["Fail build\n(CI gate)"]:::fail
    P --> PA["Coverage telemetry\n(no action)"]:::pass
    I --> IA["Annotate PR /\nqueue for next\nmanual pass"]:::warn
    N --> NA["Wiring telemetry\n(no action)"]:::neutral

    classDef fail fill:#B43A3A,stroke:#8E2828,color:#fff
    classDef pass fill:#2D7A2D,stroke:#1E5A1E,color:#fff
    classDef warn fill:#8B5E15,stroke:#6E4810,color:#fff
    classDef neutral fill:#5A5A5A,stroke:#3D3D3D,color:#fff
