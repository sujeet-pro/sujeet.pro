%% Diagram: Layered accessibility testing workflow
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph DEV["Dev time"]
        direction TB
        Lint["jsx-a11y\n36 lint rules"]:::dev
    end

    subgraph CI["CI gate"]
        direction TB
        Comp["jest-axe\ncomponent"]:::ci
        E2E["Playwright\n+ axe-core"]:::ci
        Pa["Pa11y-CI\naxe + HTMLCS"]:::ci
        LH["Lighthouse CI\n~57 audits"]:::ci
        Comp --> E2E --> Pa --> LH
    end

    subgraph MAN["Manual"]
        direction TB
        KB["Keyboard pass\ntab, focus, SPA"]:::manual
        SR["Screen readers\nNVDA / JAWS / VO"]:::manual
        EXT["WAVE / axe IGT"]:::manual
        KB --> SR --> EXT
    end

    DEV --> CI --> MAN

    classDef dev fill:#1F6E68,stroke:#155752,color:#fff
    classDef ci fill:#2E5A88,stroke:#1F4870,color:#fff
    classDef manual fill:#8B5E15,stroke:#6E4810,color:#fff
