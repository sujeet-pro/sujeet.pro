%% Diagram: Three-stage accessibility CI/CD funnel
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    subgraph S1["Stage 1 — pre-commit (sub-second)"]
        direction TB
        S1A["eslint-plugin-jsx-a11y<br/>(static AST)"]
    end

    subgraph S2["Stage 2 — pull request (seconds–minutes)"]
        direction TB
        S2A["jest-axe / vitest-axe<br/>(component)"]
        S2B["Playwright + @axe-core/playwright<br/>(E2E)"]
        S2A --- S2B
    end

    subgraph S3["Stage 3 — pre-deploy (minutes)"]
        direction TB
        S3A["Pa11y-CI<br/>axe + HTMLCS"]
        S3B["Lighthouse CI<br/>category score floor"]
        S3A --- S3B
    end

    subgraph OUT["Outputs"]
        direction TB
        VIO["violations<br/>→ fail build"]
        INC["incomplete<br/>→ tracker / digest"]
        TRI["manual triage queue"]
        VIO --- INC
        INC --- TRI
    end

    S1 --> S2
    S2 --> S3
    S3 --> OUT
