flowchart TB
    subgraph Layer1["Layer 1: Edge (WAF)"]
        WAF[AWS WAF Rules]
        IP[IP Rate Limiting]
        GEO[Geo Blocking]
    end

    subgraph Layer2["Layer 2: Application"]
        FP[Device Fingerprinting]
        BEHAV[Behavioral Analysis]
