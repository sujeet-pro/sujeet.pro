%% Diagram: Diagram 7
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
graph TB
    subgraph Edge["Edge Layer"]
        CF[CloudFront]
        WAF[AWS WAF]
    end

    subgraph Compute["Compute Layer"]
        APIGW[API Gateway]
        Lambda[Lambda Functions]
        ECS[ECS Fargate<br/>Order Workers]
    end

    subgraph Data["Data Layer"]
        ElastiCache[(ElastiCache Redis)]
        DDB[(DynamoDB)]
        RDS[(RDS PostgreSQL)]
        SQS[SQS FIFO]
    end

    subgraph Monitoring["Observability"]
        CW[CloudWatch]
        XRay[X-Ray]
    end

    Users --> CF
    CF --> WAF
    WAF --> APIGW
    APIGW --> Lambda
    Lambda --> ElastiCache
    Lambda --> DDB
    ECS --> SQS
    ECS --> RDS
    Lambda --> CW
    ECS --> XRay
