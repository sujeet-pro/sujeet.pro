%% Diagram: Choosing a priority-queue implementation
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TD
  Q["Need a priority queue"]
  Q --> Merge{"Need O(1) merge<br/>of two heaps?"}
  Merge -- "Yes" --> MergeYes{"Mergeable<br/>+ decrease-key heavy?"}
  MergeYes -- "Yes" --> Pair["Pairing heap<br/>Best practical<br/>decrease-key + meld"]
  MergeYes -- "No, just merge" --> Leftist["Leftist / skew heap<br/>O(log n) merge,<br/>simpler than pairing"]
  Merge -- "No" --> DK{"Decrease-key<br/>on the hot path?"}
  DK -- "Yes, with stable indexing" --> IdxBin["Binary heap +<br/>index map<br/>O(log n) decrease-key"]
  DK -- "Yes, simpler is fine" --> Dup["Binary heap +<br/>duplicate-node strategy<br/>(insert + skip stale)"]
  DK -- "No" --> Cache{"Heap exceeds<br/>L2 cache?"}
  Cache -- "Yes, extract-heavy" --> Dary["4-ary heap<br/>shorter tree, fewer<br/>cache misses"]
  Cache -- "No / small n" --> Bin["Binary heap<br/>default — simple,<br/>cache-friendly"]

  Theory["Need proven worst-case bounds<br/>(theory paper, real-time)?"] --> TheoryQ{"Worst-case<br/>or amortized?"}
  TheoryQ -- "Worst-case O(1) insert/merge/dec-key" --> Brodal["Brodal queue<br/>matches Fibonacci<br/>worst-case, complex"]
  TheoryQ -- "Amortized O(1) insert/dec-key" --> Fib["Fibonacci heap<br/>tight amortized bounds,<br/>slow constants"]

  classDef default fill:#e8f5e9,stroke:#2e7d32
  classDef warn fill:#fff3e0,stroke:#ef6c00
  class Fib,Brodal warn
