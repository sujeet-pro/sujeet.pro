%% Diagram: Insert + sift-up on a binary min-heap
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
  subgraph Row1[" "]
    direction LR
    subgraph Step1["1. Append 0 at end"]
      direction TB
      A0(("1"))
      A1(("3"))
      A2(("2"))
      A3(("7"))
      A4(("5"))
      A5(("4"))
      A6(("9"))
      A7(("0"))
      A0 --- A1
      A0 --- A2
      A1 --- A3
      A1 --- A4
      A2 --- A5
      A2 --- A6
      A3 --- A7
    end

    subgraph Step2["2. Swap with parent 7"]
      direction TB
      B0(("1"))
      B1(("3"))
      B2(("2"))
      B3(("0"))
      B4(("5"))
      B5(("4"))
      B6(("9"))
      B7(("7"))
      B0 --- B1
      B0 --- B2
      B1 --- B3
      B1 --- B4
      B2 --- B5
      B2 --- B6
      B3 --- B7
    end
  end

  subgraph Row2[" "]
    direction LR
    subgraph Step3["3. Swap with parent 3"]
      direction TB
      C0(("1"))
      C1(("0"))
      C2(("2"))
      C3(("3"))
      C4(("5"))
      C5(("4"))
      C6(("9"))
      C7(("7"))
      C0 --- C1
      C0 --- C2
      C1 --- C3
      C1 --- C4
      C2 --- C5
      C2 --- C6
      C3 --- C7
    end

    subgraph Step4["4. Swap with parent 1, stop at root"]
      direction TB
      D0(("0"))
      D1(("1"))
      D2(("2"))
      D3(("3"))
      D4(("5"))
      D5(("4"))
      D6(("9"))
      D7(("7"))
      D0 --- D1
      D0 --- D2
      D1 --- D3
      D1 --- D4
      D2 --- D5
      D2 --- D6
      D3 --- D7
    end
  end

  Step1 --> Step2
  Step2 --> Step3
  Step3 --> Step4
