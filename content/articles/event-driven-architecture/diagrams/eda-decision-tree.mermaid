%% Diagram: Decision tree for choosing event-driven vs request-driven and which patterns to layer on
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    Start(["New service or\nintegration point"]) --> Q1{"Strong consistency\nand immediate feedback?"}
    Q1 -- Yes --> Req["Request-driven\nHTTP / gRPC"]
    Q1 -- No --> Q2{"Multiple consumers\nor independent scaling?"}
    Q2 -- No --> Req
    Q2 -- Yes --> Events["Event-driven via broker"]

    Events --> A1{"Audit trail or\ntemporal queries?"}
    A1 -- Yes --> ES["+ Event sourcing\n(see deep-dive)"]
    A1 -- No --> A2{"Read patterns differ\nsignificantly from writes?"}
    ES --> A2
    A2 -- Yes --> CQRS["+ CQRS"]
    A2 -- No --> Sagas{"Distributed workflow?"}
    CQRS --> Sagas
    Sagas -- "2-3 steps" --> Choreo["Choreography"]
    Sagas -- "5+ steps" --> Orch["Orchestration"]
    Sagas -- No --> Done(["Single-service handler"])

    classDef sync fill:#2E5A88,stroke:#1F4870,color:#fff
    classDef async fill:#1F6E68,stroke:#155752,color:#fff
    classDef store fill:#8B5E15,stroke:#6E4810,color:#fff
    classDef hub fill:#B43A3A,stroke:#8E2828,color:#fff
    classDef mesh fill:#5A5A5A,stroke:#3D3D3D,color:#fff
    class Req sync
    class Events async
    class ES,CQRS store
    class Orch hub
    class Choreo mesh
