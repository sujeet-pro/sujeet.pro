quadrantChart
  title "Message taxonomy: intent vs payload"
  x-axis "Imperative (do X)" --> "Declarative (X happened)"
  y-axis "Reference only" --> "Carries full state"
  quadrant-1 "Event-Carried State Transfer"
  quadrant-2 "Document Message"
  quadrant-3 "Command Message"
  quadrant-4 "Event Notification"
  "ChargeCard(orderId)": [0.15, 0.18]
  "PlaceOrder(orderId)": [0.18, 0.32]
  "OrderRequest doc": [0.22, 0.82]
  "OrderPlaced (id only)": [0.78, 0.18]
  "EmailChanged (id+ts)": [0.82, 0.28]
  "OrderPlaced (full snapshot)": [0.85, 0.85]
  "ProductCatalogUpdated (full)": [0.7, 0.78]
