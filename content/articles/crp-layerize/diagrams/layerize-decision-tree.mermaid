%% Diagram: LayerizeGroup per-chunk decision flow
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Start(["PaintChunk to place"]) --> Foreign{"Foreign content?<br/>(video, canvas,<br/>plugin, OOPIF)"}
    Foreign -- yes --> NewLayer["New cc::Layer<br/>(no merge)"]
    Foreign -- no --> DCR{"Direct compositing<br/>reason on<br/>PropertyTreeState?"}
    DCR -- yes --> NewLayer
    DCR -- no --> Search["Find latest compatible<br/>PendingLayer"]
    Search --> Found{"Compatible PL<br/>found?"}
    Found -- no --> NewLayer
    Found -- yes --> Overlap{"Overlaps an intervening<br/>incompatible PL?"}
    Overlap -- yes --> NewLayer
    Overlap -- no --> Sparsity{"Within sparsity<br/>tolerance?"}
    Sparsity -- no --> NewLayer
    Sparsity -- yes --> Merge["Merge into PendingLayer<br/>(flatten differing nodes)"]

    Merge --> Done(["Next chunk"])
    NewLayer --> Done

    style NewLayer fill:#ffe0b2,stroke:#e65100,stroke-width:2px
    style Merge fill:#c8e6c9,stroke:#1b5e20,stroke-width:2px
    style Foreign fill:#fff9c4,stroke:#f9a825
    style DCR fill:#fff9c4,stroke:#f9a825
    style Found fill:#fff9c4,stroke:#f9a825
    style Overlap fill:#fff9c4,stroke:#f9a825
    style Sparsity fill:#fff9c4,stroke:#f9a825
