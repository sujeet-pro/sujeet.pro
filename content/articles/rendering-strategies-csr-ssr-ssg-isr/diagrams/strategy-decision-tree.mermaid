%% Diagram: Rendering Strategy Decision Tree
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TD
    start{"SEO or fast LCP\nrequired?"}
    auth{"Personalized\nper request?"}
    fresh{"Freshness\nbudget?"}
    catalog{"Catalog size\nand churn?"}
    mixed{"Static page with\na few dynamic holes?"}

    csr["CSR\ndashboards, tools"]
    ssr["SSR\n+ streaming / edge"]
    ssg["SSG\nbuild + CDN"]
    isr["ISR\nSSG + revalidate"]
    ppr["PPR / RSC\nshell + streamed holes"]

    start -->|"No"| csr
    start -->|"Yes"| auth
    auth -->|"Yes"| ssr
    auth -->|"No"| fresh
    fresh -->|"Real-time"| ssr
    fresh -->|"Min to hours"| isr
    fresh -->|"Release-only"| catalog
    catalog -->|"Small, stable"| ssg
    catalog -->|"Large or churning"| isr
    fresh -->|"Mixed"| mixed
    mixed -->|"Yes"| ppr
    mixed -->|"No"| isr

    classDef pick fill:#dbeafe,stroke:#1d4ed8,color:#0f172a
    class csr,ssr,ssg,isr,ppr pick
