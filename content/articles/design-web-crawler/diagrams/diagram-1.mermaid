%% Diagram: Diagram 1
%% Type: sequence
%%{init: {'htmlLabels': false}}%%
sequenceDiagram
    participant F as Frontier
    participant R as robots
    participant D as DNS
    participant H as Fetcher
    participant P as Parser
    participant DD as Dedup
    participant S as Storage

    F->>F: select URL
    F->>D: resolve
    D-->>F: IP
    F->>R: robots check
    R-->>F: ok/deny

    alt Disallowed
        F->>S: blocked
    else Allowed
        F->>H: fetch
        H-->>F: response
        alt 2xx
            F->>P: parse
            P->>P: extract
            P->>DD: fingerprint
            DD-->>P: new/dup
            alt New
                P->>S: store
                P->>DD: save fp
                loop links
                    P->>DD: seen?
                    DD-->>P: yes/no
                    alt New URL
                        P->>F: enqueue
                        P->>DD: mark seen
                    end
                end
            else Duplicate
                P->>S: ref only
            end
        else 3xx
            F->>DD: check
            F->>F: enqueue target
        else 4xx/5xx
            F->>S: retry
        end
    end
    F->>F: politeness timer
