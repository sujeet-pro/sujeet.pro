%% Diagram: Transcoding Pipeline
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph "Input"
        RAW[Raw Video] --> DEMUX[Demuxer]
        DEMUX --> VIDEO[Video Stream]
        DEMUX --> AUDIO[Audio Streams]
        DEMUX --> SUB[Subtitles]
    end

    subgraph "Analysis"
        VIDEO --> SCENE[Scene Detection]
        SCENE --> COMPLEX[Complexity Analysis\nper-segment bitrate]
    end

    subgraph "Video Encoding"
        COMPLEX --> CODECS["Codecs\nH.264 · VP9 · AV1"]
    end

    subgraph "Resolution Ladder"
        CODECS --> RES["Resolutions\n2160p · 1440p · 1080p\n720p · 480p · 360p · 240p · 144p"]
    end

    subgraph "Audio Encoding"
        AUDIO --> AUDCODECS["AAC-LC · Opus"]
    end

    subgraph "Packaging"
        RES --> SEG[Segmenter\n2-4s segments]
        AUDCODECS --> SEG
        SEG --> HLS[HLS .m3u8 + .ts/.fmp4]
        SEG --> DASH[DASH .mpd + .m4s]
    end
