%% Diagram: High Level Architecture
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Clients["Mobile & Web Clients"]
    CDN["CDN"]
    LB["Load Balancer"]
    Gateway["API Gateway"]
    Search["Search Service"]
    Ranking["Ranking Service"]
    BizUser["Business + User\nService"]
    Review["Review Service"]
    PG[("PostgreSQL")]
    ES[("Elasticsearch")]
    Redis[("Redis + Geo Cache")]
    Kafka[["Kafka"]]
    Workers["Background Workers\nML + Spam Detection"]

    Clients --> CDN --> LB --> Gateway
    Gateway --> Search
    Gateway --> BizUser
    Gateway --> Review
    Search --> ES
    Search --> Redis
    Search --> Ranking
    BizUser --> PG
    BizUser --> Redis
    Review --> PG
    Review --> Kafka --> Workers
    Workers --> ES
