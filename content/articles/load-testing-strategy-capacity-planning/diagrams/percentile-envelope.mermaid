%% Diagram: Percentile envelope vs throughput — averages hide tail growth
%% Type: xy
%%{init: {'htmlLabels': false}}%%
xychart-beta
    title "Latency percentiles vs offered throughput (illustrative)"
    x-axis "Offered throughput (relative to capacity)" [0.2, 0.4, 0.5, 0.6, 0.7, 0.8, 0.85, 0.9, 0.95, 1.0]
    y-axis "Latency (ms)" 0 --> 2500
    line "p50" [40, 45, 50, 55, 60, 70, 80, 95, 130, 220]
    line "p95" [120, 140, 160, 190, 230, 320, 430, 620, 1000, 1800]
    line "p99" [200, 240, 280, 340, 430, 600, 850, 1250, 1900, 2400]
    line "SLO p99 budget" [800, 800, 800, 800, 800, 800, 800, 800, 800, 800]
