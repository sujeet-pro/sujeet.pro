graph TD
    A["Define Test Objectives<br/>and Hypotheses"] --> B["Model Traffic Patterns<br/>and Scenarios"]
    B --> C["Prepare Infrastructure<br/>and Test Data"]
    C --> D["Execute Load Tests"]
    D --> E["Monitor and<br/>Collect Metrics"]
    E --> F{"Bottleneck<br/>Found?"}
    F -->|Yes| G["Identify Root Cause"]
    G --> H["Remediate"]
    H --> D
    F -->|No| I["Estimate Capacity"]
    I --> J["Apply Headroom<br/>Factor"]
    J --> K["Publish Capacity<br/>Plan Report"]
