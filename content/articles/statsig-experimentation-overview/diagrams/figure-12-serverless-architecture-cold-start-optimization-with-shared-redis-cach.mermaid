%% Diagram: Figure 12 Serverless Architecture Cold Start Optimization With Shared Redis Cach
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
graph TB
    subgraph "AWS Lambda"
        A[Lambda Function] --> B{Statsig Initialized?}
        B -->|No| C[Initialize SDK]
        B -->|Yes| D[Use Existing Instance]
        C --> E[Load from Redis]
        D --> F[Local Evaluation]
        E --> F
        F --> G[Return Result]
    end

    subgraph "Redis Cache"
        H[Config Cache] --> I[Shared State]
    end

    E --> H
    D --> H

    style A fill:#e1f5fe
    style G fill:#c8e6c9
    style H fill:#fff3e0
