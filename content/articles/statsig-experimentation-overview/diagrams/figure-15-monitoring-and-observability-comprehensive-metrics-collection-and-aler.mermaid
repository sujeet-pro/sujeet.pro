%% Diagram: Figure 15 Monitoring And Observability Comprehensive Metrics Collection And Aler
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
graph TB
    subgraph "Application"
        A[Statsig SDK] --> B[Health Check]
        B --> C[Performance Metrics]
        C --> D[Error Tracking]
    end

    subgraph "Monitoring System"
        E[Metrics Collector] --> F[Alerting]
        E --> G[Dashboard]
        E --> H[Logs]
    end

    B --> E
    C --> E
    D --> E

    subgraph "Key Metrics"
        I[Evaluation Latency]
        J[Cache Hit Rate]
        K[Sync Success Rate]
        L[Error Rates]
    end

    C --> I
    C --> J
    C --> K
    D --> L

    style A fill:#e1f5fe
    style E fill:#c8e6c9
    style I fill:#fff3e0
    style L fill:#f3e5f5
