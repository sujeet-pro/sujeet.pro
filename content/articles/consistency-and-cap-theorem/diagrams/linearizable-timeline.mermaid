%% Diagram: Linearizable timeline — operations as wall-clock intervals with linearization points
%% Type: gantt
%%{init: {'htmlLabels': false}}%%
gantt
    title Linearization points must respect real-time order across clients
    dateFormat  X
    axisFormat  %S

    section Client A
    write(x=1)        :done,    a1, 0, 4
    read(x) -> 1      :active,  a2, 6, 9

    section Client B
    read(x) -> 1      :active,  b1, 5, 8
    write(x=2)        :done,    b2, 9, 13

    section Client C
    read(x) -> 2      :active,  c1, 14, 17
