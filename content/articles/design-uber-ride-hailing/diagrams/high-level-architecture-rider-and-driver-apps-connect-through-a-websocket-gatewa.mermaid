%% Diagram: High Level Architecture
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Clients["Rider + Driver Apps"]
    GW["API Gateway\nLB · Auth · Rate Limit"]
    WS["WebSocket Gateway"]
    CORE["Core Services\nRide · Matching (DISCO) · Location\nPricing · Routing & ETA · Payment"]
    QUEUES["Kafka\nLocation + Match Queues"]
    DATA["Data Layer\nTrip Store · Redis+H3 · Cassandra · Analytics"]
    ML["ML Platform\nDeepETA · Surge · Fraud"]

    Clients --> GW --> CORE
    Clients <--> WS
    WS --> QUEUES --> CORE
    CORE --> DATA
    CORE --> ML
