%% Diagram: FairPlay SPC/CKC key exchange
%% Type: sequence
%%{init: {'htmlLabels': false}}%%
sequenceDiagram
    participant App as App
    participant FPS as FairPlay (OS)
    participant SE as Secure Enclave
    participant KSM as KSM (license server)

    App->>FPS: HLS EXT-X-KEY skd://content-id
    FPS->>SE: derive session key, build SPC
    SE-->>FPS: SPC blob<br/>(device + content id + nonce)
    FPS-->>App: SPC
    App->>KSM: POST SPC + entitlement
    KSM->>KSM: validate, lookup key, apply policy
    KSM-->>App: CKC<br/>(content key wrapped to session)
    App->>FPS: provide CKC
    FPS->>SE: unwrap CKC, install key
    SE-->>FPS: key bound to hw path
    FPS-->>App: playback proceeds
