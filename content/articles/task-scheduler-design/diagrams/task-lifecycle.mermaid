%% Diagram: Task Scheduler Lifecycle
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    SUBMIT["Submit task"] --> STORE["Persist (DB or broker)"]
    STORE --> CLAIM["Scheduler claims work<br/>(row lock / leader / hash)"]
    CLAIM --> ASSIGN["Assign to worker"]
    ASSIGN --> EXEC["Worker executes<br/>(emits heartbeats)"]
    EXEC --> SUCCESS["Success → ack"]
    EXEC --> FAIL["Failure / timeout"]
    FAIL --> RETRY{"Retry budget<br/>left?"}
    RETRY -->|Yes, with backoff| STORE
    RETRY -->|No| DLQ["Dead-letter queue"]

    classDef good fill:#d5e8d4,stroke:#82b366,color:#000
    classDef bad fill:#f8cecc,stroke:#b85450,color:#000
    classDef warn fill:#fff2cc,stroke:#d6b656,color:#000
    class SUCCESS good
    class FAIL bad
    class DLQ warn
