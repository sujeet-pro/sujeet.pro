%% Diagram: Task Scheduler Lifecycle
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph LIFE["Task Lifecycle"]
        SUBMIT["Submit task"] --> STORE["Persist in queue / DB"]
        STORE --> SCHEDULE["Scheduler claims work"]
        SCHEDULE --> ASSIGN["Assign to worker"]
        ASSIGN --> EXECUTE["Worker executes"]
        EXECUTE --> SUCCESS["Success"]
        EXECUTE --> FAIL["Failure"]
        FAIL --> RETRY{"Retry budget left?"}
        RETRY -->|Yes, with backoff| STORE
        RETRY -->|No| DLQ["Dead letter queue"]
    end

    subgraph COORD["Coordination layer"]
        LEADER["DB row locks<br/>or leader election"]
        PARTITION["Task partitioning<br/>or work stealing"]
        HEARTBEAT["Heartbeat<br/>monitoring"]
    end

    subgraph STORAGE["Storage options"]
        DB[(Relational DB)]
        BROKER[Message broker<br/>Redis / RabbitMQ / Kafka]
        HYBRID["Hybrid: DB + broker"]
    end

    SCHEDULE -.->|claim| LEADER
    ASSIGN -.->|route| PARTITION
    EXECUTE -.->|liveness| HEARTBEAT
    STORE -.-> DB
    STORE -.-> BROKER
    STORE -.-> HYBRID

    classDef good fill:#d5e8d4,stroke:#82b366,color:#000
    classDef bad fill:#f8cecc,stroke:#b85450,color:#000
    classDef warn fill:#fff2cc,stroke:#d6b656,color:#000
    class SUCCESS good
    class FAIL bad
    class DLQ warn
