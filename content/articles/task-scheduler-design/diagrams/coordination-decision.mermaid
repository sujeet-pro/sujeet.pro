%% Diagram: Coordination mechanism decision tree
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TD
    START([Pick coordination]) --> Q1{"Throughput?"}
    Q1 -->|< 10K/s| Q2{"Strict global<br/>ordering?"}
    Q1 -->|10K-100K/s| Q3{"Affinity needed?"}
    Q1 -->|> 100K/s| Q4{"Heterogeneous<br/>workers?"}

    Q2 -->|Yes| LEADER["Leader election<br/>Raft / etcd / ZK"]
    Q2 -->|No| LOCKS["DB row locks<br/>SKIP LOCKED"]

    Q3 -->|Yes| HASH["Consistent hashing"]
    Q3 -->|No| BROKER["Broker pull queue<br/>Kafka / NATS"]

    Q4 -->|Yes| STEAL["Work stealing"]
    Q4 -->|No| BROKER

    classDef pick fill:#d5e8d4,stroke:#82b366,color:#000
    class LOCKS,LEADER,HASH,BROKER,STEAL pick
