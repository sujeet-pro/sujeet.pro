%% Diagram: Commit synchronization
%% Type: sequence
%%{init: {'htmlLabels': false}}%%
sequenceDiagram
    participant MT as ProxyMain<br/>(Main)
    participant CT as ProxyImpl<br/>(Compositor)
    participant PT as Pending Tree
    participant AT as Active Tree

    Note over MT: Paint complete<br/>(trees + paint records)
    MT->>CT: NotifyReadyToCommit<br/>(forwards mutex)
    activate MT
    Note over MT: Blocked on mutex
    activate CT
    CT->>PT: Push properties,<br/>trees, paint records<br/>(by layer id)
    CT-->>MT: Release mutex
    deactivate MT
    Note over MT: Free for frame N+1

    Note over CT: Schedule raster
    CT->>PT: Raster tiles
    Note over PT: Required tiles ready
    CT->>AT: Activate (pending → active)
    deactivate CT
    Note over AT: Ready for Draw
