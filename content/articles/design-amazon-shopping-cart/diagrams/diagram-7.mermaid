%% Diagram: Diagram 7
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph "us-east-1 (Primary)"
        ALB1[ALB]
        ECS1[ECS Cluster]
        RDS1[(RDS Primary)]
        Redis1[(ElastiCache)]
    end

    subgraph "us-west-2 (Secondary)"
        ALB2[ALB]
        ECS2[ECS Cluster]
        RDS2[(RDS Replica)]
        Redis2[(ElastiCache)]
    end

    Route53[Route 53<br/>Latency Routing]
    GlobalAcc[Global Accelerator]

    Route53 --> GlobalAcc
    GlobalAcc --> ALB1
    GlobalAcc --> ALB2
    RDS1 -.->|Async Replication| RDS2
