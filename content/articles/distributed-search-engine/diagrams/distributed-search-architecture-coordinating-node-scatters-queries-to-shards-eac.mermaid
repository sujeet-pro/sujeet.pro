%% Diagram: Distributed Search Architecture
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    CL[Application]
    QP[Query Parser]
    AGG[Result Aggregator]

    subgraph SHARD["Shard (replicated 0..N)"]
        PRIMARY["Shard Primary"]
        REPLICA["Shard Replica"]
        INDEX["Index\nSegments · Inverted · FST"]
        PRIMARY -.->|sync| REPLICA
        PRIMARY --> INDEX
    end

    CL -->|query| QP -->|scatter| PRIMARY
    PRIMARY -->|local results| AGG
    AGG -->|merged top-K| CL
