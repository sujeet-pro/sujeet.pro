%% Diagram: Playback startup timeline — sub-2s budget
%% Type: gantt
gantt
    title Playback startup budget (target: first frame < 2s)
    dateFormat X
    axisFormat %Lms
    section Network setup
    DNS lookup (cached)             :done, dns,    0, 20
    TLS 1.3 handshake (0-RTT)       :done, tls,    20, 70
    section Manifest and license
    Manifest fetch (edge-cached)    :active, mani, 70, 170
    License acquisition (parallel)  :active, lic,  170, 370
    section First media
    First segment fetch (small)     :crit, seg,    170, 670
    Decode and render first frame   :crit, dec,    670, 870
