%% Diagram: Whatwg Processing Model Task Microtasks Rendering Idle
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
graph TB
    subgraph TaskPhase["Task phase"]
        direction TB
        A[Event Loop Iteration] --> B[Select Task from Queue]
        B --> C[Execute Task]
        C --> D[Call Stack Empty?]
        D -->|No| C
    end

    subgraph MicrotaskPhase["Microtask checkpoint"]
        direction TB
        E[Microtask Checkpoint]
        F[Drain Microtask Queue]
        E --> F
    end

    subgraph RenderPhase["Render phase"]
        direction TB
        G[Update Rendering?]
        H[Run rAF Callbacks]
        I[Style Recalculation]
        J["Layout/Reflow"]
        K[Paint]
        L[Composite]
        G -->|Yes| H --> I --> J --> K --> L
    end

    subgraph IdlePhase["Idle phase"]
        direction TB
        M[Idle Period]
        N[requestIdleCallback]
        M --> N
    end

    D -->|Yes| E
    F --> G
    G -->|No| M
    L --> M
    N --> A
