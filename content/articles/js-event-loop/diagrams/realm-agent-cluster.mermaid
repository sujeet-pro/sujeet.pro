%% Diagram: Realm × Agent × Agent Cluster nesting per ECMA-262
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    subgraph cluster["Agent Cluster — shared memory boundary (SharedArrayBuffer)"]
        direction TB
        subgraph agentA["Agent A — window main thread, CanBlock=false"]
            direction LR
            realmA1["Realm 1\nglobalThis, intrinsics"]:::realm
            realmA2["Realm 2\nsame-origin iframe"]:::realm
        end

        subgraph agentB["Agent B — Worker, CanBlock=true"]
            realmB1["Realm\nworker globalThis"]:::realm
        end

        subgraph agentC["Agent C — Worker, CanBlock=true"]
            realmC1["Realm\nworker globalThis"]:::realm
        end

        agentA -. "postMessage / SharedArrayBuffer" .-> agentB
        agentB -. "Atomics.wait / notify\n(CanBlock=true agents only)" .-> agentC
    end

    note["Per agent: own execution context stack,\nrunning execution context, Agent Record,\nexecuting thread. One Job at a time per agent."]:::note

    classDef realm fill:#2E5A88,stroke:#1F4870,color:#fff
    classDef note fill:#5A5A5A,stroke:#3D3D3D,color:#fff
