%% Diagram: Spec-defined host enqueue hooks and the constraints each one carries
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph engine["Engine triggers"]
        gen["Engine-internal\nbookkeeping"]:::engine
        prom["Promise.then,\nawait, async fn body"]:::engine
        timeout["setTimeout / setInterval\n(host-defined)"]:::engine
        gc["WeakRef / FinalizationRegistry\ncleanup"]:::engine
    end

    subgraph hooks["Host hook (§9.5)"]
        hg["HostEnqueueGenericJob\nno priority, no order"]:::generic
        hp["HostEnqueuePromiseJob\nFIFO, same-realm prep,\npromise priority"]:::promise
        ht["HostEnqueueTimeoutJob\n>= milliseconds delay"]:::timeout
        hf["HostEnqueueFinalizationRegistryCleanupJob\noptional, may never run"]:::finalize
    end

    subgraph contract["Common contract for all Jobs"]
        c1["Run only when execution context\nstack of the agent is empty"]:::contract
        c2["Job Abstract Closure must return\na normal completion (handle errors)"]:::contract
        c3["After invocation, stack must be\nempty again"]:::contract
    end

    gen --> hg
    prom --> hp
    timeout --> ht
    gc --> hf

    hg --> contract
    hp --> contract
    ht --> contract
    hf --> contract

    classDef engine fill:#2E5A88,stroke:#1F4870,color:#fff
    classDef generic fill:#5A5A5A,stroke:#3D3D3D,color:#fff
    classDef promise fill:#1F6E68,stroke:#155752,color:#fff
    classDef timeout fill:#8B5E15,stroke:#6E4810,color:#fff
    classDef finalize fill:#B43A3A,stroke:#8E2828,color:#fff
    classDef contract fill:#2D7A2D,stroke:#1E5A1E,color:#fff
