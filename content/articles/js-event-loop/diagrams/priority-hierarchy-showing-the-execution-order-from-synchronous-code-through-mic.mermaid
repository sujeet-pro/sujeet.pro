%% Diagram: Priority Hierarchy Showing The Execution Order From Synchronous Code Through Mic
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
graph TD
    subgraph "Execution Priority"
        A[Synchronous Code] --> B[nextTick Queue]
        B --> C[Microtask Queue]
        C --> D[Macrotask Queue]
        D --> E[Event Loop Phases]
    end

    subgraph "Macrotask Sources"
        F[setTimeout/setInterval]
        G[I/O Operations]
        H[User Events]
        I[Network Requests]
    end

    subgraph "Microtask Sources"
        J[Promise callbacks]
        K[queueMicrotask]
        L[MutationObserver]
    end

    F --> D
    G --> D
    H --> D
    I --> D
    J --> C
    K --> C
    L --> C
