%% Diagram: Six Phases Of The Node Js Event Loop
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
graph TD
    A[Event Loop Tick] --> B[timers]
    B --> C[pending callbacks]
    C --> D[idle, prepare]
    D --> E[poll]
    E --> F[check]
    F --> G[close callbacks]
    G --> A

    subgraph "Phase Details"
        H[setTimeout/setInterval] --> B
        I[System Errors] --> C
        J[I/O Callbacks] --> E
        K[setImmediate] --> F
        L[Close Events] --> G
    end
