%% Diagram: Workers Have Independent Event Loops
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
graph TB
    MAIN["Main Thread\nMain Event Loop + UI"]
    POST["postMessage"]
    CH["Message Channel"]
    TRANSFER["Transfer Modes\nClone (copy)\nTransferable (zero-copy)\nSharedArrayBuffer (shared)"]
    WORKER["Worker Thread\nWorker Event Loop + bg"]
    ONMSG["onmessage Handler"]

    MAIN --> POST --> CH
    TRANSFER --> CH
    CH --> WORKER --> ONMSG
    ONMSG --> POST
