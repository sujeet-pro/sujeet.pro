%% Diagram: All Rendering Models Csr Ssr Rsc Use The Fiber Reconciler Ssr And Rsc Require Hy
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Fiber["Fiber Reconciler"]
        direction LR
        Render["Render Phase<br/>(Interruptible, 5ms slices)"]
        Commit["Commit Phase<br/>(Synchronous)"]
        Render --> Commit
    end

    subgraph Execution["Rendering Models"]
        direction TB
        CSR["CSR<br/>Client builds DOM"]
        SSR["SSR/Streaming<br/>Server renders HTML"]
        RSC["RSC<br/>Server components + Flight"]
    end

    Fiber --> CSR
    Fiber --> SSR
    Fiber --> RSC

    SSR --> Hydration["Hydration<br/>Attach React to SSR HTML"]
    RSC --> Flight["Flight stream<br/>Server component payload"]
    Flight --> ClientBoundaries["Hydrate client boundaries<br/>where interactivity exists"]
