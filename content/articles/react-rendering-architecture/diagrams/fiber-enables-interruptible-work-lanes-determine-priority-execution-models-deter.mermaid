%% Diagram: Architecture Layers
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Foundation["Foundation Layer"]
        Fiber["Fiber\nVirtual call stack"]
    end

    subgraph Scheduling["Priority Layer"]
        Lanes["Lanes\n31-bit priority bitmask"]
    end

    subgraph Concurrency["Concurrency Primitives"]
        Suspense["Suspense\nasync render boundary"]
        Transitions["Transitions\nstartTransition / useDeferredValue"]
    end

    subgraph Execution["Execution Models"]
        CSR["CSR"]
        SSR["SSR / Streaming"]
        RSC["RSC"]
    end

    Fiber --> Lanes
    Lanes --> Suspense
    Lanes --> Transitions
    Suspense --> CSR
    Suspense --> SSR
    Suspense --> RSC
