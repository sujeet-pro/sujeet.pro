%% Diagram: High Level Architecture
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    CLIENTS["Clients\nReader · Writer · Appender"]

    subgraph MetadataLayer["Metadata Layer"]
        MASTER["Master Server\nNameNode"]
        SHADOW["Shadow Master\nHot Standby"]
        OPLOG[("Operation Log\n+ Checkpoints")]
    end

    subgraph StorageLayer["Storage Layer"]
        PRIMARY["Primary Chunk Server\nDataNode"]
        REPLICAS["Replica Chunk Servers\nDataNodes"]
    end

    CLIENTS -->|"1. Metadata Request"| MASTER
    MASTER -->|"2. Chunk Locations"| CLIENTS
    CLIENTS -->|"3. Read / Write Data"| PRIMARY
    PRIMARY -->|"4. Pipeline Replication"| REPLICAS
    MASTER <--> SHADOW
    MASTER --> OPLOG
