%% Diagram: Diagram 2
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Producer
        P[App] --> IP[Idempotent Producer]
        IP -->|"PID + SeqNum"| B
    end

    subgraph Broker["Kafka Broker"]
        B[Leader] -->|"Check SeqNum"| D{Duplicate?}
        D -->|Yes| R[Reject]
        D -->|No| W[Write to Log]
    end

    subgraph Consumer
        W --> C[Consumer]
        C -->|"read_committed"| CP[Consumer Processing]
    end
