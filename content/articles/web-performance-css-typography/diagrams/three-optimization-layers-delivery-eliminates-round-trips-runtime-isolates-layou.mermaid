%% Diagram: Three Optimization Layers Delivery Eliminates Round Trips Runtime Isolates Layou
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    subgraph "Delivery Layer"
        direction TB
        CRIT["Critical CSS<br/>≤14KB inline"]
        DEFER["Non-critical<br/>Deferred load"]
    end

    subgraph "Runtime Layer"
        direction TB
        CONTAIN["Containment<br/>Isolate subtrees"]
        COMPOSITE["Compositor<br/>transform/opacity"]
    end

    subgraph "Font Layer"
        direction TB
        FORMAT["WOFF2 + Subset"]
        METRIC["Metric Overrides<br/>Zero-CLS swap"]
    end

    CRIT --> CONTAIN
    DEFER --> CONTAIN
    CONTAIN --> COMPOSITE
    FORMAT --> METRIC
