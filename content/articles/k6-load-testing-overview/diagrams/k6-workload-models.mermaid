%% Diagram: k6 workload models — closed vs open
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
graph LR
    subgraph Closed["Closed model (VU-based)"]
        direction TB
        C1["Pin: VU count N"] --> C2["Each VU loops:\niter -> sleep -> iter"]
        C2 --> C3["When SUT slows,\nthroughput drops with it"]
        C3 --> C4["Emergent: throughput (RPS)"]
        C4 --> CE["Executors:\nconstant-vus, ramping-vus,\nper-vu-iterations, shared-iterations"]
    end

    subgraph Open["Open model (arrival-rate)"]
        direction TB
        O1["Pin: iteration rate R/s"] --> O2["Scheduler starts a new iteration\nevery 1/R, regardless of finish"]
        O2 --> O3["When SUT slows,\nVU count grows to keep R\n(up to maxVUs)"]
        O3 --> O4["Emergent: VU count, queue depth"]
        O4 --> OE["Executors:\nconstant-arrival-rate,\nramping-arrival-rate"]
    end

    Closed -.->|"Tail latency hidden:\ncoordinated omission"| Risk["Use open when SLO is\nRPS or P95 latency"]
    Open -.->|"Real tail measured"| Risk
