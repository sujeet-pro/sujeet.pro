%% Diagram: k6 metrics → thresholds pipeline
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph VU["Per-VU runtime"]
        direction TB
        Iter["Iteration\nhttp.get / check"] --> Sample["Sample\nname + value + tags"]
    end

    Sample --> Bus["Metrics bus\n(Go channel)"]
    Bus --> Sink["Output sink\nstdout / JSON / Prom / xk6-output"]
    Bus --> Agg["Aggregator\nper-metric type"]

    Agg --> Counter["Counter\nmonotonic sum"]
    Agg --> Gauge["Gauge\nlast value"]
    Agg --> Rate["Rate\n% non-zero"]
    Agg --> Trend["Trend\nmin/avg/p95/p99"]

    Counter --> Eval["Threshold evaluator\nper options.thresholds"]
    Gauge --> Eval
    Rate --> Eval
    Trend --> Eval

    Eval --> Result{"All thresholds\nsatisfied?"}
    Result -- yes --> Pass["exit 0\nCI gate passes"]
    Result -- no --> Fail["exit 99\nCI gate fails"]
