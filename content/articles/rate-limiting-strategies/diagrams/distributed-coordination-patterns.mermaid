%% Diagram: Three distributed rate-limiting coordination patterns
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph A["A. Shared state — exact, +1 hop per request"]
        direction LR
        A1["App instance 1"] --> A_redis[("Redis Cluster\nLua EVAL\natomic check + incr")]
        A2["App instance 2"] --> A_redis
        A3["App instance N"] --> A_redis
    end

    subgraph B["B. Local approximation — fast, brief overage"]
        direction LR
        B1["App instance 1\nlocal counter"] -.->|"periodic sync"| B_store[("Shared store\n(reconcile)")]
        B2["App instance 2\nlocal counter"] -.->|"periodic sync"| B_store
        B3["App instance N\nlocal counter"] -.->|"periodic sync"| B_store
    end

    subgraph C["C. Hybrid — local burst absorber + global enforcement"]
        direction LR
        C1["App instance 1\nlocal token bucket\nabsorbs bursts"] --> C_global["Global rate-limit svc\ngRPC -> Redis"]
        C2["App instance 2\nlocal token bucket"] --> C_global
        C3["App instance N\nlocal token bucket"] --> C_global
    end

    classDef primary fill:#2E5A88,stroke:#1F4870,color:#ffffff
    classDef storage fill:#8B5E15,stroke:#6E4810,color:#ffffff
    classDef secondary fill:#1F6E68,stroke:#155752,color:#ffffff
    class A1,A2,A3,C1,C2,C3 primary
    class B1,B2,B3 secondary
    class A_redis,B_store,C_global storage
