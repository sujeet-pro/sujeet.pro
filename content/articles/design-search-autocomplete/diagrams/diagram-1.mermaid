%% Diagram: Diagram 1
%% Type: sequence
%%{init: {'htmlLabels': false}}%%
sequenceDiagram
    participant C as Client
    participant CDN
    participant GW as Gateway
    participant R as Router
    participant T as Trie
    participant Ca as Redis
    participant Rk as Ranker

    C->>CDN: GET /suggest
    alt Hit
        CDN-->>C: results
    else Miss
        CDN->>GW: forward
        GW->>R: by prefix
        R->>Ca: hot cache
        alt Hot Hit
            Ca-->>R: cached
        else Miss
            R->>T: query shard
            T-->>R: top-K
        end
        R->>Rk: personalize
        Rk-->>GW: ranked
        GW-->>CDN: response
        CDN-->>C: results
    end
