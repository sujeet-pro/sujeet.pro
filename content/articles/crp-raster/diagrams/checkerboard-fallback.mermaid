%% Diagram: Checkerboard fallback decision and recovery
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    Scroll["Scroll:<br/>new tiles<br/>enter NOW"] --> Check{"NOW tile<br/>rasterized?"}
    Check -- "yes" --> Draw["Display compositor<br/>draws fresh tile"]
    Check -- "no" --> LowRes{"Low-res<br/>tiling?"}
    LowRes -- "yes" --> DrawLow["Draw low-res tile<br/>(transient blur)"]
    LowRes -- "no" --> DrawCheck["Draw checkerboard<br/>(empty quad)"]
    DrawLow --> Schedule["TileManager raises priority<br/>+ schedules raster"]
    DrawCheck --> Schedule
    Schedule --> Raster["Raster worker<br/>fills high-res tile"]
    Raster --> Replace["Next BeginFrame swaps<br/>in fresh tile (drawn)"]
