%% Diagram: Three-tree (pending / active / recycle) lifecycle in cc
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Main["Main thread<br/>property tree"]
    Pending["Pending tree<br/>(receives commit)"]
    Workers["Raster worker pool"]
    Active["Active tree<br/>(currently drawn)"]
    Recycle["Recycle tree<br/>(cached buffers)"]
    Display["Display compositor"]

    Main -- "commit" --> Pending
    Pending -- "raster req" --> Workers
    Workers -- "tiles ready" --> Pending
    Pending -- "activate when<br/>NOW tiles ready" --> Active
    Active -- "retired on<br/>next activation" --> Recycle
    Recycle -- "buffers reused" --> Pending
    Active --> Display
