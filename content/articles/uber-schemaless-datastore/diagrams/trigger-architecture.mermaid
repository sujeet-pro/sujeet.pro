%% Diagram: Trigger architecture
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Schemaless["Schemaless instance (per-shard log)"]
        direction LR
        S1[("Shard 1")]
        S2[("Shard 2")]
        S3[("Shard 3")]
        S4[("Shard 4")]
    end

    subgraph Workers["Trigger workers (up to 4096 per instance)"]
        direction LR
        W1["Worker 1<br/>shard 1"]
        W2["Worker 2<br/>shards 2,5"]
        W3["Worker 3<br/>shards 3,4"]
    end

    Coord[("Coordinator<br/>ZooKeeper or<br/>Schemaless itself")]
    Leader{"Leader worker"}

    S1 --> W1
    S2 --> W2
    S3 --> W3
    S4 --> W3

    W1 -->|"persist last added_id"| Coord
    W2 --> Coord
    W3 --> Coord

    Coord -.->|"leader election"| Leader
    Leader -.->|"reassign on failure"| Workers
