%% Diagram: Buffered writes
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    Req["Worker: PUT cell<br/>(row_key, column, ref_key)"]

    subgraph Sec["Secondary cluster (random)"]
        SecMaster[("Secondary master<br/>buffer table")]
    end

    subgraph Pri["Primary cluster (shard N)"]
        direction TB
        PriMaster[("Primary master<br/>entity table")]
        Min1[("Minion DC2")]
        Min2[("Minion DC3")]
        PriMaster -. "async repl" .-> Min1
        PriMaster -. "async repl" .-> Min2
    end

    Reaper{"Background reaper"}

    Req -->|"1. write to buffer"| SecMaster
    Req -->|"2. write to entity"| PriMaster
    Reaper -->|"poll for cell"| Min1
    Reaper -->|"on hit, delete buffer"| SecMaster
