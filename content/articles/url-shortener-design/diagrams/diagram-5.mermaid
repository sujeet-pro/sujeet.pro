%% Diagram: URL Shortener - Request Path
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Clients
        BROWSER["Browser"]
        SDK["API SDKs"]
        WEBHOOK["Webhook Consumers"]
    end

    subgraph Edge["Edge Layer"]
        CDN["CDN\n(Redirect Cache)"]
        WAF["WAF\n(DDoS)"]
        LB["Load Balancer"]
    end

    subgraph API["API Gateway"]
        RATE["Rate Limiter"]
        AUTH["Auth"]
        ROUTER["Router"]
    end

    subgraph Core["Core Services"]
        SHORTEN_SVC["Shortening"]
        REDIRECT_SVC["Redirect"]
        KGS_SVC["Key Generation"]
        USER_SVC["User"]
        LINK_SVC["Link Mgmt"]
    end

    BROWSER & SDK & WEBHOOK --> CDN
    CDN -->|Miss| WAF --> LB
    LB --> RATE --> AUTH --> ROUTER
    ROUTER --> SHORTEN_SVC & REDIRECT_SVC & LINK_SVC
    SHORTEN_SVC --> KGS_SVC
