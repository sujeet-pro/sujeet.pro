%% Diagram: URL Shortener - Backing Services
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    SHORTEN_SVC["Shortening Svc"]
    REDIRECT_SVC["Redirect Svc"]
    USER_SVC["User Svc"]

    URL_SCAN["URL Scanner"]
    ABUSE["Abuse Detection"]
    BLOCKLIST["Blocklist"]

    COLLECTOR["Click Collector"]
    KAFKA["Kafka"]
    PROCESSOR["Stream Processor"]
    CLICKHOUSE[(ClickHouse)]

    REDIS["Redis"]
    CASS[(Cassandra)]
    PG[(PostgreSQL)]

    SHORTEN_SVC --> URL_SCAN --> BLOCKLIST
    SHORTEN_SVC --> REDIS
    SHORTEN_SVC --> CASS
    REDIRECT_SVC --> REDIS
    REDIRECT_SVC -->|Miss| CASS
    REDIRECT_SVC --> COLLECTOR --> KAFKA --> PROCESSOR --> CLICKHOUSE
    USER_SVC --> PG
    ABUSE --> REDIS
