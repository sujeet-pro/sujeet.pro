%% Diagram: Cache Stampede Mechanism and Mitigations
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    subgraph stampede["Problem (no mitigation)"]
        direction TB
        s_exp["Hot key TTL expires"] --> s_burst["N concurrent requests miss"]
        s_burst --> s_thunder["All N hit origin"]
        s_thunder --> s_overload["Origin saturates;<br/>cache stays cold"]
    end

    subgraph mitigations["Three independent mitigations (combine freely)"]
        direction TB
        subgraph m_single["Single-flight / coalescing"]
            direction TB
            sf_miss["Miss for K"] --> sf_dedup["Local map keyed by K:<br/>only first fetch runs"]
            sf_dedup --> sf_share["All waiters share<br/>the same Promise"]
        end
        subgraph m_lock["Distributed lock"]
            direction TB
            l_miss["Miss"] --> l_acquire["One node acquires<br/>lock on K (SETNX)"]
            l_acquire --> l_fetch["Fetch + write back"]
            l_fetch --> l_others["Others serve stale<br/>or short-poll"]
        end
        subgraph m_xfetch["Probabilistic refresh (XFetch)"]
            direction TB
            x_check["On read, evaluate:<br/>now − δ·β·ln(rand) ≥ expiry"] --> x_decide{"Triggered?"}
            x_decide -- yes --> x_async["Async refresh,<br/>serve current"]
            x_decide -- no --> x_serve["Serve cached"]
        end
    end

    classDef bad fill:#B43A3A,stroke:#8E2828,color:#ffffff
    classDef ok fill:#1F6E68,stroke:#155752,color:#ffffff
    classDef neutral fill:#5A5A5A,stroke:#3D3D3D,color:#ffffff

    class s_exp,s_burst neutral
    class s_thunder,s_overload bad
    class l_acquire,l_fetch,sf_dedup,sf_share,x_async,x_serve ok
    class l_miss,sf_miss,x_check,x_decide,l_others neutral
