%% Diagram: Migration approach decision tree
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    A["Need a schema<br/>or data change"] --> B{"Data transform<br/>required?"}
    B -- "No,<br/>schema only" --> C{"INSTANT DDL<br/>supported?"}
    C -- "Yes" --> C1["MySQL ALGORITHM=INSTANT<br/>or PG metadata-only ALTER"]
    C -- "No" --> D{"Table size and<br/>write load?"}
    D -- "Small,<br/>low writes" --> D1["Direct ALTER<br/>(INPLACE/COPY)"]
    D -- "Large,<br/>FK present" --> D2["pt-osc<br/>(triggers)"]
    D -- "Large,<br/>high writes,<br/>no FK" --> D3["gh-ost / Spirit<br/>(binlog)"]
    D -- "Postgres,<br/>bloat / reorg" --> D4["pg_repack"]
    B -- "Yes,<br/>data + schema" --> E["Expand-contract<br/>+ throttled backfill<br/>(or pgroll on PG)"]
    B -- "Cross-DB<br/>or sharding" --> F["CDC + strangler<br/>(Vitess, custom proxy)"]
