%% Diagram: Library-as-product overview — API, governance, and operations layers
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph API["Component API Layer"]
        direction LR
        COMP[Compound Components]
        POLY[Polymorphic Props]
        A11Y[Built-in A11y]
    end

    subgraph GOV["Governance Layer"]
        direction LR
        RFC[RFC Process]
        CONTRIB[Contribution Model]
        REVIEW[Review Gates]
    end

    subgraph OPS["Operations Layer"]
        direction LR
        VER[Versioning]
        DOCS[Documentation]
        METRICS[Adoption Metrics]
    end

    API --> GOV
    GOV --> OPS
    OPS -->|Feedback| API
