%% Diagram: Multi Bitrate Encoding Each Track Encoded To 4 Quality Levels For Adaptive Strea
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph "Ingestion"
        MASTER[Master Audio<br/>WAV/FLAC] --> INGEST[Ingestion Service]
    end

    subgraph "Encoding"
        INGEST --> Q24[Ogg Vorbis<br/>24 kbps · low / data saver]
        INGEST --> Q96[Ogg Vorbis<br/>96 kbps · normal]
        INGEST --> Q160[Ogg Vorbis<br/>160 kbps · high]
        INGEST --> Q320[Ogg Vorbis<br/>320 kbps · very high]
        INGEST --> AAC[AAC<br/>128 / 256 kbps · web]
        INGEST --> FLAC[FLAC lossless<br/>16/24-bit · 44.1 kHz · 2025]
    end

    subgraph "Storage"
        Q24 & Q96 & Q160 & Q320 & AAC & FLAC --> GCS[(Cloud Storage)]
        GCS --> META[(Metadata DB)]
    end
