%% Diagram: Sharding Partitions Data Horizontally Replication Copies Each Shard For Fault To
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Clients
        C1[Client]
        C2[Client]
        C3[Client]
    end

    subgraph Router["Router / Proxy"]
        R[Shard Router]
    end

    subgraph Shard1["Shard 1 (users A-M)"]
        L1[Leader]
        F1a[Follower]
        F1b[Follower]
        L1 --> F1a
        L1 --> F1b
    end

    subgraph Shard2["Shard 2 (users N-Z)"]
        L2[Leader]
        F2a[Follower]
        F2b[Follower]
        L2 --> F2a
        L2 --> F2b
    end

    C1 --> R
    C2 --> R
    C3 --> R
    R --> L1
    R --> L2
    R -.->|reads| F1a
    R -.->|reads| F2a
