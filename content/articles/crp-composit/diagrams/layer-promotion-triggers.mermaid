%% Diagram: What triggers layer promotion (direct compositing reasons)
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Author["Author hints"]
        direction TB
        WC["will-change: transform / opacity / filter"]
        T3D["transform: translateZ(0) /<br/>translate3d() / perspective"]
        BF["backface-visibility: hidden"]
    end

    subgraph Animation["Animations"]
        direction TB
        ANIM["@keyframes / transition on<br/>transform, opacity"]
        SVA["scroll-driven /<br/>view-transition surfaces"]
    end

    subgraph Foreign["Foreign GPU surfaces"]
        direction TB
        VIDEO["composited &lt;video&gt;"]
        CANVAS["accelerated &lt;canvas&gt; / WebGL / WebGPU"]
        IFRAME["cross-origin &lt;iframe&gt; (OOPIF)"]
    end

    subgraph Scrolling["Scroll-related"]
        direction TB
        FIXED["position: fixed (in scroller)"]
        STICKY["position: sticky"]
        SCROLLER["composited overflow scroller"]
    end

    Overlap["Overlap above a promoted layer<br/>(squashing-style cascade)"]

    Author --> DCR
    Animation --> DCR
    Foreign --> DCR
    Scrolling --> DCR
    Overlap --> DCR

    DCR["Direct compositing reason<br/>recorded on PropertyTreeState"] --> LAYER["Own cc::Layer<br/>after layerization"]
    LAYER --> COST["Costs: GPU memory ≈ width × height × 4 × DPR²,<br/>extra draw calls,<br/>re-raster on resize / scale change"]
