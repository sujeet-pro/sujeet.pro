%% Diagram: Protocol Evolution Overview
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph H1["HTTP/1.1 — RFC 9112"]
        direction TB
        H1A["6 TCP conns per origin"]
        H1B["App-layer HOL"]
        H1C["Plain-text headers"]
    end

    H1 -.->|"frames + HPACK"| H2

    subgraph H2["HTTP/2 — RFC 9113"]
        direction TB
        H2A["1 TCP + TLS conn"]
        H2B["Multiplexed streams"]
        H2C["HPACK compression"]
    end

    H2 -.->|"TCP HOL on loss"| H3

    subgraph H3["HTTP/3 — RFC 9114"]
        direction TB
        H3A["QUIC over UDP"]
        H3B["Per-stream recovery"]
        H3C["No transport HOL"]
    end

    classDef legacy fill:#8B5E15,stroke:#6E4810,color:#ffffff
    classDef current fill:#2E5A88,stroke:#1F4870,color:#ffffff
    classDef next fill:#1F6E68,stroke:#155752,color:#ffffff

    class H1A,H1B,H1C legacy
    class H2A,H2B,H2C current
    class H3A,H3B,H3C next
