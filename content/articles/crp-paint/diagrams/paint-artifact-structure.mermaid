%% Diagram: Paint Artifact Structure
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Chunk1["Paint Chunk #1 — root state"]
        direction TB
        P1[PropertyTreeState: t=root, c=root, e=root, s=root]
        DI1[DrawingDisplayItem: body background]
        DI2[DrawingDisplayItem: header borders]
        P1 --- DI1 --- DI2
    end

    subgraph Chunk2["Paint Chunk #2 — transformed card"]
        direction TB
        P2[PropertyTreeState: t=card.transform, c=root, e=root, s=root]
        DI3[DrawingDisplayItem: card background]
        DI4[DrawingDisplayItem: card text]
        P2 --- DI3 --- DI4
    end

    subgraph Chunk3["Paint Chunk #3 — clipped scroller"]
        direction TB
        P3[PropertyTreeState: t=root, c=overflow.clip, e=root, s=scroll]
        DI5[ScrollHitTestDisplayItem]
        DI6[DrawingDisplayItem: list items]
        P3 --- DI5 --- DI6
    end

    Chunk1 --> Chunk2 --> Chunk3 --> Layerize[Layerize: chunk to cc::Layer mapping]

    style Chunk2 stroke:#2e7d32,stroke-width:2px
    style Chunk3 stroke:#1565c0,stroke-width:2px
    style Layerize fill:#e3f2fd,stroke:#1565c0
