%% Diagram: Payment System Architecture Client Apps Submit Payments Through An Idempotent Ap
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    CLIENTS["Clients\nWeb / Mobile / POS"]
    API["Payment API\n(Idempotent)"]
    FRAUD["Fraud Engine"]
    ROUTER["Smart Router"]
    AUTH["Authorization"]
    CAPTURE["Capture"]
    REFUND["Refund"]
    NETWORKS["Card Networks\nVisa / MC / ACH / Wallets"]
    LEDGER[(Ledger)]
    VAULT[(Token Vault)]
    EVENTS["Kafka"]

    CLIENTS --> API
    API --> FRAUD --> ROUTER --> AUTH
    AUTH --> NETWORKS
    AUTH --> CAPTURE
    CAPTURE --> LEDGER
    CAPTURE --> EVENTS
    API --> VAULT
    REFUND --> LEDGER
