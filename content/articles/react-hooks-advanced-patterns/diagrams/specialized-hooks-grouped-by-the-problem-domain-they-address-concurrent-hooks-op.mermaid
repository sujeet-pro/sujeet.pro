%% Diagram: Specialized Hooks Grouped By The Problem Domain They Address Concurrent Hooks Op
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph "Concurrent Rendering"
        direction TB
        useTransition["useTransition\nNon-blocking state updates"]
        useDeferredValue["useDeferredValue\nDefer non-critical values"]
    end

    subgraph "Effect Timing"
        direction TB
        useLayoutEffect["useLayoutEffect\nBefore paint (DOM measurement)"]
        useInsertionEffect["useInsertionEffect\nBefore layout (CSS injection)"]
    end

    subgraph "External Integration"
        direction TB
        useSyncExternalStore["useSyncExternalStore\nExternal store subscription"]
        use["use\nPromise/Context consumption"]
    end

    subgraph "SSR & Accessibility"
        direction TB
        useId["useId\nStable unique IDs"]
    end
