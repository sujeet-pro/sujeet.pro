%% Diagram: useDeferredValue two-phase render
%% Type: sequence
sequenceDiagram
    participant U as User
    participant I as Input
    participant R as React
    participant L as List

    U->>I: Type "ab"
    I->>R: setQuery("ab") urgent
    R->>I: Render query="ab"
    R->>L: Render deferred="a" (stale)
    Note over L: Fast: cached result
    R-->>R: Schedule bg render deferred="ab"
    U->>I: Type "abc" before bg commits
    I->>R: setQuery("abc") urgent
    R->>R: Abandon stale bg render
    R->>I: Render query="abc"
    R->>L: Render deferred="a" (still stale)
    R-->>R: Schedule bg render deferred="abc"
    R->>L: Bg commit deferred="abc"
    Note over L: query == deferred, isStale=false
