%% Diagram: Shopify Pod Architecture
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TD
    subgraph "Request Path"
        LB["nginx + OpenResty\nLoad Balancers"] --> SH["Sorting Hat\n(Lua)"]
        SH -->|"Pod header"| APP["Shared App Workers\n(Kubernetes)"]
    end

    subgraph "Pod (replicated 1..N)"
        MYSQL["MySQL Shard"]
        REDIS["Redis"]
        MEMCACHED["Memcached"]
        CRON["Cron"]
    end

    APP -->|"shop_id routing"| MYSQL

    subgraph "Cross-Pod Analytics (Read-Only)"
        CDC["Debezium CDC"] --> KAFKA["Apache Kafka"]
        KAFKA --> DW["Data Warehouse\nPresto"]
    end

    MYSQL -.->|"binlog"| CDC
