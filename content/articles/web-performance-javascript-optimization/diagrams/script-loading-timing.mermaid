%% Diagram: Parser vs script execution timing across loading modes
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph BLOCK["Blocking — no attribute"]
        B1["Parser pauses for fetch + execute"] --> B2(("DCL"))
    end

    subgraph ASYNC["async"]
        A1["Parse + parallel fetch"] --> A2["Pause + execute on arrival"] --> A3(("DCL"))
    end

    subgraph DEFER["defer"]
        D1["Parse + parallel fetch"] --> D2["Execute in document order"] --> D3(("DCL"))
    end

    subgraph MODULE["type=module — deferred + graph resolve"]
        M1["Parse + fetch module graph"] --> M2["Resolve + execute"] --> M3(("DCL"))
    end

    BLOCK --> ASYNC --> DEFER --> MODULE

    style B1 fill:#ffcdd2,stroke:#c62828
    style A2 fill:#fff9c4,stroke:#f9a825
    style D2 fill:#c8e6c9,stroke:#2e7d32
    style M2 fill:#c8e6c9,stroke:#2e7d32
