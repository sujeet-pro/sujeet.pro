%% Diagram: Implementation lifecycle — decisions in each layer constrain what is possible in the next
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Architecture["Architecture (decided once)"]
        direction LR
        ARCH[Framework strategy]
        TOKENS[Token pipeline]
        COMP[Component primitives]
    end

    subgraph Distribution["Distribution (continuously tuned)"]
        direction LR
        BUNDLE[Bundling + exports]
        REGISTRY[Registry + versioning]
        ASSETS[Shared CDN assets]
    end

    subgraph Operations["Operations (run as a product)"]
        direction LR
        CI[CI gates]
        ANALYTICS[Usage analytics]
        DEPRECATION[Deprecation policy]
        CODEMODS[Codemods]
    end

    ARCH --> TOKENS --> COMP
    BUNDLE --> REGISTRY --> ASSETS
    CI --> ANALYTICS --> DEPRECATION --> CODEMODS

    Architecture --> Distribution
    Distribution --> Operations
    Operations -.->|"signals next iteration"| Architecture

    classDef arch fill:#2E5A88,stroke:#1F3F60,color:#ffffff
    classDef dist fill:#2D7A2D,stroke:#1B4D1B,color:#ffffff
    classDef ops fill:#8B5E15,stroke:#5C3F0E,color:#ffffff
    class ARCH,TOKENS,COMP arch
    class BUNDLE,REGISTRY,ASSETS dist
    class CI,ANALYTICS,DEPRECATION,CODEMODS ops
