%% Diagram: Implementation lifecycle — decisions in each layer constrain what is possible in the next
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph Architecture["Architecture (decided once, expensive to revisit)"]
        ARCH[Framework strategy]
        TOKENS[Token pipeline]
        COMP[Component primitives]
        ARCH --> TOKENS --> COMP
    end

    subgraph Distribution["Distribution (continuously tuned)"]
        BUNDLE[Bundling + exports]
        REGISTRY[Registry + versioning]
        ASSETS[Shared CDN assets]
        BUNDLE --> REGISTRY
        REGISTRY --> ASSETS
    end

    subgraph Operations["Operations (run as a product)"]
        CI[CI gates: visual / a11y / perf]
        ANALYTICS[Usage analytics]
        DEPRECATION[Deprecation policy]
        CODEMODS[Codemods]
        CI --> ANALYTICS
        ANALYTICS --> DEPRECATION
        DEPRECATION --> CODEMODS
    end

    COMP --> BUNDLE
    ASSETS --> CI
    CODEMODS -.->|"signals next architecture iteration"| ARCH
