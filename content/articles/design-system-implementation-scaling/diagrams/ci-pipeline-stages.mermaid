%% Diagram: CI pipeline stages for a design-system monorepo
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    PR((PR opened))

    subgraph Fast["Fast feedback (< 2 min)"]
        direction TB
        LINT[Lint + typecheck]
        UNIT[Unit + interaction tests]
    end

    subgraph Quality["Quality gates (parallel)"]
        direction TB
        VR[Visual regression<br/>Chromatic / Percy]
        A11Y[Accessibility<br/>axe + Storybook addon]
        BUDGET[Bundle budgets<br/>size-limit / bundlewatch]
        BUILD[Library build<br/>Vite / Rollup]
    end

    subgraph Release["Release (main only)"]
        direction TB
        CHANGE[Changesets bot opens<br/>Version Packages PR]
        PUB[Publish to registry +<br/>generate codemods]
    end

    PR --> LINT --> UNIT
    UNIT --> VR
    UNIT --> A11Y
    UNIT --> BUDGET
    UNIT --> BUILD

    BUILD -. main merge .-> CHANGE --> PUB

    classDef fast fill:#dbeafe,stroke:#1e40af,color:#1f2937
    classDef gate fill:#fef3c7,stroke:#92400e,color:#1f2937
    classDef rel fill:#dcfce7,stroke:#166534,color:#1f2937
    class LINT,UNIT fast
    class VR,A11Y,BUDGET,BUILD gate
    class CHANGE,PUB rel
