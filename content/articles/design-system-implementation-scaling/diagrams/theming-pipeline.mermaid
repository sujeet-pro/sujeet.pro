%% Diagram: Theming token pipeline from design source of truth to platform outputs
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    FIGMA["Figma variables\n(Tokens Studio export)"]
    DTCG["DTCG JSON (W3C 2025.10)\n$value / $type / $description"]

    subgraph Build["Build engines"]
        direction LR
        SD[Style Dictionary v4]
        TZ[Terrazzo]
    end

    subgraph Outputs["Platform outputs"]
        direction TB
        WEB["Web: CSS variables, ESM tokens"]
        MOBILE["Mobile: iOS Swift, Android XML"]
        TW["Tailwind preset"]
    end

    FIGMA --> DTCG
    DTCG --> SD
    DTCG --> TZ
    SD --> WEB
    SD --> MOBILE
    TZ --> WEB
    TZ --> TW

    classDef src fill:#8B5E15,stroke:#5C3F0E,color:#ffffff
    classDef spec fill:#2E5A88,stroke:#1F3F60,color:#ffffff
    classDef build fill:#1F6E68,stroke:#134743,color:#ffffff
    classDef out fill:#2D7A2D,stroke:#1B4D1B,color:#ffffff
    class FIGMA src
    class DTCG spec
    class SD,TZ build
    class WEB,MOBILE,TW out
