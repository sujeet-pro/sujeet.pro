%% Diagram: Kinesis Front-End and Back-End Architecture (US-EAST-1, Nov 2020)
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    CLIENT["Kinesis API clients\n(PutRecord / GetRecords)"]

    subgraph FE["Front-End Fleet (monolithic, many thousands of servers)"]
        direction LR
        FE1["Front-end server"]
        FE2["Front-end server"]
        FEN["Front-end server"]
        FE1 <-. "thread-per-peer\nshard-map gossip\n(O(N) per server)" .-> FE2
        FE2 <-. " " .-> FEN
        FE1 <-. " " .-> FEN
    end

    subgraph SOURCES["Shard-map cache sources"]
        direction LR
        MS["Membership\nmicroservice"]
        DDB["DynamoDB\n(authoritative\nconfig)"]
        PEERS["Peer messages\nfrom other\nfront-end servers"]
    end

    subgraph BE["Back-End (already cell-based)"]
        direction LR
        C1["Cell-cluster A\n(shards 1..k)"]
        C2["Cell-cluster B\n(shards k+1..m)"]
        C3["Cell-cluster N\n(shards m+1..n)"]
    end

    CLIENT --> FE
    FE --> SOURCES
    FE --> BE

    classDef frontend fill:#B43A3A,stroke:#8E2828,color:#ffffff
    classDef sources fill:#2E5A88,stroke:#1F4870,color:#ffffff
    classDef backend fill:#2D7A2D,stroke:#1E5A1E,color:#ffffff
    class FE1,FE2,FEN frontend
    class MS,DDB,PEERS sources
    class C1,C2,C3 backend
