%% Diagram: The Thundering Herd Loop That Constrained Recovery Speed Restarting Too Many Ser
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    A["Restart<br/>servers"] --> B["Shard-map<br/>construction<br/>consumes CPU"]
    B --> C["Few resources<br/>for requests"]
    C --> D["Health checks<br/>fail"]
    D --> E["Servers removed<br/>from fleet"]
    E --> A

    style D fill:#B43A3A,stroke:#8E2828,color:#ffffff
    style E fill:#B43A3A,stroke:#8E2828,color:#ffffff
