%% Diagram: Thread-per-peer Scaling Across a Capacity Addition
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    subgraph BEFORE["Before capacity addition (N servers)"]
        direction TB
        B1["Per-server threads ≈ (N-1) gossip\n+ request-handling threads"]
        B2["Headroom remaining\nunder OS thread limit"]
        B1 --> B2
    end

    subgraph AFTER["After capacity addition (N + ΔN servers)"]
        direction TB
        A1["Per-server threads ≈ (N + ΔN - 1) gossip\n+ request-handling threads"]
        A2["Per-server threads\nEXCEED OS limit"]
        A3["Shard-map construction\nfails silently → 'useless' maps"]
        A1 --> A2 --> A3
    end

    NOTE["Aggregate threads across the fleet ≈ N·(N-1) → O(N²).\nThe hard ceiling is per-process, so adding capacity makes it WORSE per-server."]

    BEFORE --> AFTER
    AFTER --> NOTE

    classDef alert fill:#B43A3A,stroke:#8E2828,color:#ffffff
    classDef info fill:#5A5A5A,stroke:#3D3D3D,color:#ffffff
    class A2,A3 alert
    class NOTE info
