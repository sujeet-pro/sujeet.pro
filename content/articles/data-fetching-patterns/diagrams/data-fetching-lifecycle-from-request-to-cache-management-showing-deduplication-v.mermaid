%% Diagram: Data Fetching Lifecycle From Request To Cache Management Showing Deduplication V
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    REQ["Request\nKey + Params"]
    DEDUPE["Deduplication"]
    CACHE["Cache Layer"]
    FETCH["Network Fetch"]
    VALID["Validation\nETag"]
    REVALID["Background Revalidate"]

    REQ --> DEDUPE
    DEDUPE -->|"Hit"| CACHE
    DEDUPE -->|"Miss"| FETCH
    CACHE -->|"Stale"| REVALID
    FETCH --> VALID
    VALID -->|"304 / 200"| CACHE
    REVALID --> FETCH

    FRESH["Fresh"] --> STALE["Stale"] --> INACTIVE["Inactive"] --> GC["GC"]
