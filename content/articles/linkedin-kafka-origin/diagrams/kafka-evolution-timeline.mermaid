%% Diagram: Kafka evolution from first commit to KRaft-only
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart LR
    subgraph Origin["2010-2014: Birth and validation"]
        direction TB
        Y2010["2010\nfirst Kafka code at LinkedIn\nZooKeeper for coordination + offsets"]
        Y2011["2011\nopen-sourced (Jan)\nNetDB paper (Jun)\n1B msg/day at LinkedIn (Jul)"]
        Y2013["2012-2013\nApache top-level project\n0.8 leader/follower replication"]
        Y2014["2014\n2M writes/sec benchmark\nConfluent founded\nI Heart Logs (book)"]
    end

    subgraph Maturity["2015-2019: Maturity and scale"]
        direction TB
        Y2015["2015\n0.9 offsets move to __consumer_offsets\nnew Java consumer"]
        Y2017["2017\n0.11 idempotent producer + transactions\nexactly-once semantics"]
        Y2019["2019\nLinkedIn at 7T msg/day\nBrooklin open-sourced"]
    end

    subgraph Modern["2022-2025: Re-architecture"]
        direction TB
        Y2022["2022\n3.3 KRaft marked production-ready\n(KIP-833)"]
        Y2024["2024\n3.9 tiered storage GA\n(KIP-405)"]
        Y2025["2025\n4.0 ZooKeeper removed, KRaft only"]
    end

    Origin --> Maturity --> Modern

    classDef era fill:#e6f0ff,stroke:#1f3a8a,color:#0b1d4d
    class Y2010,Y2011,Y2013,Y2014,Y2015,Y2017,Y2019,Y2022,Y2024,Y2025 era
