%% Diagram: Pre-Resolution Cache Lookup Chain
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    App["Application / browser request"] --> BC{"Browser HTTP / Host cache?"}
    BC -- "hit" --> Done["Connect using cached IP"]
    BC -- "miss" --> Sys["OS resolver API (getaddrinfo)"]
    Sys --> Hosts{"hosts file / NSS first?"}
    Hosts -- "match" --> Done
    Hosts -- "no match" --> mDNS{"name ends in .local?"}
    mDNS -- "yes" --> Multicast["mDNS multicast (224.0.0.251 / FF02::FB)"]
    mDNS -- "no" --> OSCache{"OS / system cache?"}
    OSCache -- "hit" --> Done
    OSCache -- "miss" --> Stub["Stub resolver: query configured recursive"]
    Stub --> Recursive["Recursive resolver (ISP / 1.1.1.1 / 8.8.8.8)"]
    Recursive --> Iter["Iterative walk: root, TLD, authoritative"]
