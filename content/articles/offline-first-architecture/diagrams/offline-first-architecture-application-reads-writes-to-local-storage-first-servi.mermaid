flowchart TB
    subgraph Client["Client (Browser)"]
        direction TB
        App[Application]
        SW[Service Worker]
        IDB[(IndexedDB)]
        Cache[(Cache API)]
    end

    subgraph Server["Server"]
        API[API Server]
        DB[(Database)]
    end

    App -->|"1. Read/Write"| IDB
    App -->|"2. UI renders immediately"| App
    SW -->|"3. Intercept requests"| Cache
    SW <-->|"4. Background sync"| API
    IDB <-->|"5. Conflict resolution"| API
    API <--> DB
