flowchart LR
    subgraph Origin["Origin Servers"]
        O1[Primary Origin]
        O2[Failover Origin]
    end

    subgraph Shield["Origin Shield"]
        S[Shield PoP]
    end

    subgraph Edge["Edge PoPs"]
        E1[Edge Location 1]
        E2[Edge Location 2]
        E3[Edge Location N]
    end

    subgraph Clients["Clients"]
        C1[Browser]
        C2[Mobile App]
        C3[API Consumer]
    end

    O1 --> S
    O2 --> S
    S --> E1
    S --> E2
    S --> E3
    E1 --> C1
    E2 --> C2
    E3 --> C3

    style S fill:#f9f,stroke:#333
