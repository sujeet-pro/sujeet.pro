%% Diagram: Node.js ESM loader pipeline with customization hooks
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
  spec["import / require(esm)"]

  subgraph Hooks["customization hooks (LIFO chains)"]
    direction LR
    res["resolve hook(s)\n→ default resolve\n(exports, conditions)"]
    load["load hook(s)\n→ default load\n(read bytes, format)"]
    res --> load
  end

  subgraph V8["V8 module pipeline"]
    direction LR
    parse["parse → ModuleRecord"]
    link["link imports"]
    eval["evaluate (top-level await)"]
    parse --> link --> eval
  end

  cache["module cache by URL"]

  spec --> Hooks --> V8 --> cache

  classDef io fill:#2E5A88,stroke:#1F4870,color:#ffffff
  classDef hook fill:#8B5E15,stroke:#6E4810,color:#ffffff
  classDef v8s fill:#1F6E68,stroke:#155752,color:#ffffff
  class spec,cache io
  class res,load hook
  class parse,link,eval v8s
