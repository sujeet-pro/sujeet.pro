%% Diagram: Google Search Architecture Queries Flow Through Spell Correction And Intent Unde
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    USERS["Users\nWeb / Mobile / API"]

    subgraph QP["Query Processing"]
        SPELL["Spell"]
        INTENT["Intent"]
        EXPAND["Expansion"]
    end

    subgraph Serving["Serving"]
        ROUTER["Query Router"]
        CACHE[(Query Cache)]
        AGG["Aggregator"]
    end

    SHARDS[(Index Shards\nInverted)]

    subgraph Ranking["Ranking"]
        PAGERANK["PageRank"]
        BERT["BERT"]
        RANKBRAIN["RankBrain"]
    end

    subgraph Crawl["Crawl"]
        FRONTIER["Frontier"]
        CRAWLER["Crawler"]
        PARSER["Parser"]
    end

    BIGTABLE[(Bigtable)]
    COLOSSUS[(Colossus)]

    USERS --> SPELL --> INTENT --> EXPAND --> ROUTER
    ROUTER --> CACHE
    ROUTER --> SHARDS
    SHARDS --> AGG
    AGG --> PAGERANK & BERT & RANKBRAIN
    PAGERANK --> USERS
    BERT --> USERS
    RANKBRAIN --> USERS

    FRONTIER --> CRAWLER --> PARSER --> BIGTABLE --> COLOSSUS
    PARSER --> SHARDS
