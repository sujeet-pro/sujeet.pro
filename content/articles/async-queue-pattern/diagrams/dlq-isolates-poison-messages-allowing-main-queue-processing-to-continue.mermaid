%% Diagram: Dlq Isolates Poison Messages Allowing Main Queue Processing To Continue
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
graph TB
    MQ[(Main Queue)] --> W[Worker]
    W -->|Success| Done[✓]
    W -->|Retry| MQ
    W -->|Max attempts exceeded| DLQ[(DLQ)]
    DLQ -->|Manual review| Fix[Fix & Replay]

    classDef queueClass fill:#5A5A5A,stroke:#3D3D3D,color:#ffffff,stroke-width:2px
    classDef workerClass fill:#2E5A88,stroke:#1F4870,color:#ffffff,stroke-width:2px
    classDef dlqClass fill:#B43A3A,stroke:#8E2828,color:#ffffff,stroke-width:2px

    class MQ queueClass
    class W workerClass
    class DLQ dlqClass
