%% Diagram: Dom Interface Inheritance Hierarchy Showing Element As The Universal Base For Al
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    ET[EventTarget] --> Node
    Node --> Element
    Element --> HTMLElement["HTMLElement\nHTML-specific"]
    Element --> SVGElement["SVGElement\nSVG-specific"]
    Element --> MathMLElement["MathMLElement\nMathML-specific"]

    classDef primary fill:#2E5A88,stroke:#1F4870,color:#ffffff
    classDef secondary fill:#5A5A5A,stroke:#3D3D3D,color:#ffffff
    class Element primary
    class ET,Node secondary
