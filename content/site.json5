{
  // Site metadata
  origin: "https://sujeet.pro",
  name: "Sujeet Jaiswal",
  title: "Sujeet Jaiswal - Principal Software Engineer",
  description: "Personal blog and portfolio of Sujeet Jaiswal, a Principal Software Engineer crafting exceptional user experiences through innovative frontend architecture and scalable design systems.",
  language: "en-US",

  // Build config (from site.config.ts)
  baseUrl: "/",
  defaultLayout: "Page",
  styles: ["reset.css", "theme.css", "base.css", "code.css", "layout.css", "components.css"], // deprecated — kept for reference
  css: {
    entries: ["styles/main.css"],
    minify: true,
  },
  markdown: {
    shiki: {
      themes: { light: "github-light", dark: "github-dark" },
      defaultShowLineNumbers: true,
      langAlias: {
        redis: "bash",
        vcl: "nginx",
        promql: "plaintext",
        logql: "plaintext",
        bind: "nginx",
        dns: "ini",
        cql: "sql",
        properties: "ini",
        m3u8: "bash",
        asciidoc: "markdown",
      },
    },
  },

  // Navigation
  navItems: [
    { path: "/articles", label: "Articles" },
    { path: "/blogs", label: "Blogs" },
    { path: "/projects", label: "Projects" },
  ],
  footerLinks: [
    { path: "/cv", label: "Resume" },
    { path: "/tags", label: "Tags" },
  ],

  // Social & copyright
  social: {
    twitter: {
      handle: "@sujeetpro",
      url: "https://twitter.com/sujeetpro",
    },
    github: {
      handle: "sujeet-pro",
      url: "https://github.com/sujeet-pro",
    },
    linkedin: {
      handle: "sujeetkrjaiswal",
      url: "https://www.linkedin.com/in/sujeetkrjaiswal/",
    },
  },
  copyright: {
    holder: "Sujeet Jaiswal",
    startYear: 2024,
  },

  // Featured content
  featuredArticles: [
    "design-uber-ride-hailing",
    "consistency-and-cap-theorem",
    "frontend-architecture-at-scale",
    "web-performance-infrastructure-stack",
    "v8-engine-architecture",
  ],
  featuredSeries: ["system-design-scenarios", "critical-rendering-path", "js-runtime-internals"],

  // Page types
  pageTypes: ["articles", "blogs", "projects"],

  // Analytics
  analytics: {
    googleAnalytics: "G-1Z2TP5LG65",
  },

  // SEO
  seo: {
    locale: "en_US",
    twitterHandle: "@sujeetpro",
    defaultOgType: "website",
  },

  // Theme colors (for meta tags)
  theme: {
    lightColor: "#f8fafc",
    darkColor: "#020617",
  },

  // Home page config
  home: {
    pageTitle: "Sujeet Jaiswal - Principal Software Engineer",
    pageDescription: "Personal blog and portfolio of Sujeet Jaiswal, a Principal Software Engineer crafting exceptional user experiences through innovative frontend architecture and scalable design systems.",
    profile: {
      name: "Sujeet Jaiswal",
      title: "Principal Software Engineer",
      bio: "Principal Software Engineer focused on frontend architecture, design systems, and end-to-end system design, with a strong emphasis on infra and architecture for scale, reliability, and performance.",
      imageAlt: "Sujeet Jaiswal - Principal Software Engineer",
    },
    profileActions: {
      linkedin: "LinkedIn",
      viewCv: "CV",
      randomArticle: "I'm Feeling Lucky",
      allArticles: "All Articles",
    },
  },
}
