%% Diagram: macOS dot-files bootstrap flow
%% Type: flowchart
%%{init: {'htmlLabels': false}}%%
flowchart TB
    A["curl bootstrap-remote.sh\nor ./setup.sh"] --> B["Install Xcode CLI\n+ Homebrew + Ansible"]
    B --> C["Copy .zshenv.example → ~/.zshenv\nfill name, email, SSH keys"]
    C --> PLAY["ansible-playbook setup.yml\n--ask-become-pass"]

    PLAY --> ROLES["9 Ansible roles\nhomebrew · mise · shell · git · ssh\napps · aws · dev-tools · macos"]

    ROLES --> RESULT["Packages installed\nconfigs symlinked or templated\nmacOS defaults applied"]

    RESULT --> CLEANUP["Cleanup check\nbrew leaves vs vars\ncode --list-extensions vs vars"]
    CLEANUP --> CHOICE{"Per unmanaged item"}
    CHOICE -- add --> ADD["Append to roles vars\nrepo now matches system"]
    CHOICE -- remove --> REMOVE["Uninstall from system\nrepo wins"]
    CHOICE -- skip --> SKIP["Decide later"]

    classDef bootstrap fill:#2E5A88,stroke:#1F4870,color:#ffffff
    classDef play fill:#1F6E68,stroke:#155752,color:#ffffff
    classDef cleanup fill:#8B5E15,stroke:#6E4810,color:#ffffff
    classDef decision fill:#5A5A5A,stroke:#3D3D3D,color:#ffffff
    class A,B,C bootstrap
    class PLAY,ROLES,RESULT play
    class CLEANUP,ADD,REMOVE,SKIP cleanup
    class CHOICE decision
