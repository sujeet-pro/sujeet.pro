// Canonical tag taxonomy for sujeet.pro.
//
// Keys are canonical kebab-case slugs. `displayName` is what surfaces in
// listings, cards, and content meta. `aliases` collapse to the canonical
// slug at load time, so authors can write "JS", "javascript", "ecmascript",
// or "es6" in an article and the rendered tag is always "JavaScript".
//
// Matching is case-insensitive and ignores `_`, `.`, and whitespace, so
// "Web Vitals", "web_vitals", and "web-vitals" all collapse to the same tag.
//
// Add new entries here whenever a new topic is introduced; otherwise a raw
// frontmatter tag falls through with title-cased text.

{
  // ── Languages and runtimes ─────────────────────────────────────────────
  javascript: {
    displayName: "JavaScript",
    shortName: "JS",
    aliases: ["js", "ecmascript", "es", "es6", "es2015", "es2017", "es2020", "es2021", "esnext"],
  },
  typescript: {
    displayName: "TypeScript",
    shortName: "TS",
    aliases: ["ts"],
  },
  nodejs: {
    displayName: "Node.js",
    aliases: ["node", "nodejs", "node-js", "node.js"],
  },
  v8: {
    displayName: "V8",
    aliases: ["v8-engine"],
  },
  runtime: {
    displayName: "Runtime",
    aliases: ["runtimes", "language-runtime"],
  },
  "event-loop": {
    displayName: "Event Loop",
    aliases: ["eventloop", "event-loops"],
  },
  programming: {
    displayName: "Programming",
    aliases: ["programming-languages"],
  },

  // ── Browser, web platform, frontend ───────────────────────────────────
