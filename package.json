{
  "name": "v5.sujeet.pro",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx scripts/dev.ts",
    "preview": "tsx scripts/preview.ts",
    "build": "tsx scripts/diagrams.ts && tsx scripts/build.ts",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "validate": "tsx scripts/validate.ts",
    "validate:orphans": "tsx scripts/check-orphans.ts",
    "validate:dist": "tsx scripts/validate-dist.ts",
    "test": "vp test",
    "test:e2e": "BASE_PATH=/v5.sujeet.pro npx playwright test",
    "test:e2e:deployed": "DEPLOYED_URL=https://projects.sujeet.pro BASE_PATH=/v5.sujeet.pro npx playwright test",
    "diagrams": "tsx scripts/diagrams.ts",
    "diagrams:watch": "tsx scripts/diagrams.ts --watch",
    "diagrams:force": "tsx scripts/diagrams.ts --force",
    "ci": "npm run check && npm run validate && npm run test && npm run build && npm run validate:dist && npm run test:e2e"
  },
  "dependencies": {
    "@pagesmith/core": "^0.4.2",
    "diagramkit": "^0.1.0",
    "json5": "^2.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "vite-plus": "latest",
    "vitest": "^4.1.3",
    "ws": "^8.20.0"
  },
  "packageManager": "npm@11.12.1"
}
